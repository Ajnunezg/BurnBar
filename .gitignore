# Xcode
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
# Embedded workspace holds SwiftPM lockfile — un-ignore parents so Package.resolved can be tracked
!*.xcodeproj/project.xcworkspace/
!*.xcodeproj/project.xcworkspace/contents.xcworkspacedata
!*.xcodeproj/project.xcworkspace/xcshareddata/
!*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
!*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
*.xcworkspace/*
!*.xcworkspace/contents.xcworkspacedata
!*.xcworkspace/xcshareddata/

# Build
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
# Package.resolved — committed for reproducible builds

# CocoaPods
Pods/

# Carthage
Carthage/Build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
Library/Logs/

# Python
__pycache__/
*.py[cod]

# Xcode private settings
*.mode1v3
*.mode2v3
*.perspectivev3
*.xcuserstate
xcuserdata/

# Thumbnails
*.swp
*.swo
*~

# IDEs
*.idea/
*.vscode/
.cursor/plans/

# Secrets
*.env
*.pem
*.p12
*.p8
*.mobileprovision
*.provisionprofile
*.developerprofile
.encryption-key-recovery

# Sentry — DSN is non-secret but keep local overrides out of source
sentry.properties

# Firebase — never commit the real plist; drop it locally as GoogleService-Info.plist
GoogleService-Info.plist

# Local test/build artifacts
.playwright-mcp/
output/playwright/
default.profraw

# BurnBar local MCP (Python venv)
tools/burnbar-mcp/.venv/

# Internal AI agent memory (not for public consumption)
.claude/agent-memory/
.claude/settings.local.json
.claude/*.lock

# Generated validation logs (keep JSON reports, skip raw test logs)
.factory/validation/**/user-testing/*.log

# Local Xcode/SwiftPM caches used by scripts/build.sh
.spm-cache/
.derived-data/
.derived-data-*/
.derived-*/
derived-data/

# Local service installs/build outputs
services/**/node_modules/
services/**/lib/

# Local-only Factory skills and xcodegen scratch
.factory/skills/
.xcodegen-validate/
.gstack/

# Accidental SwiftPM/protobuf checkouts at repo root
/Sources/protobuf/

# Generated Xcode derived data emitted by factory validation runs
.factory/validation/**/user-testing/derived-data/

# Generated SwiftPM checkout/artifact mirrors from factory validations
.factory/validation/**/derived-data/**/SourcePackages/

# Per-test UserDefaults plists Xcode emits next to source files when running
# tests from inside the IDE (NSUserDefaults host-app simulation).
*.swift.plist

# QA harness output (qa skill writes timestamped reports + screenshots)
qa-results/
