---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProviderTable from "@components/ProviderTable.astro";
import {
  PROVIDERS_PRIMARY,
  PROVIDERS_DETECTED,
  CONFIDENCE_LABEL,
  CONFIDENCE_BLURB,
  type Confidence
} from "@data/providers";

const confidenceKeys: Confidence[] = ["exact", "estimated", "unavailable"];
---

<BaseLayout
  title="Providers"
  description="The honest provider support matrix for OpenBurnBar — Claude Code, Codex, OpenAI, Copilot, Cursor, Factory, MiniMax, Z.ai, Warp, Ollama, Kimi and more."
>
  <section class="pagehead">
    <div class="container">
      <span class="eyebrow eyebrow--ember">Providers</span>
      <h1 class="pagehead__h">An honest provider matrix.</h1>
      <p class="lead">
        Eleven providers ship with real usage data today. Eight more are detected
        but expose no usage API — we mark them so, rather than pretending.
        Confidence labels live on every row.
      </p>
    </div>
  </section>

  <section class="legend" aria-label="Confidence legend">
    <div class="container">
      <ol class="legend__grid">
        {confidenceKeys.map((k) => (
          <li class={`legend__card legend__card--${k}`}>
            <header>
              <span class={`tag tag--plain mono tag--${k}`}>{k}</span>
            </header>
            <h3>{CONFIDENCE_LABEL[k]}</h3>
            <p>{CONFIDENCE_BLURB[k]}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section>
    <div class="container">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Real usage data · today</span>
        <h2>Eleven providers ship with live data.</h2>
        <p class="lead">
          Each one names exactly where data comes from, what we can know
          about cost, and how quota is shaped. Notes capture limitations
          we'd rather you read than discover later.
        </p>
      </header>
      <ProviderTable rows={PROVIDERS_PRIMARY} />
    </div>
  </section>

  <section class="detected">
    <div class="container">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Detection-only</span>
        <h2>Vendors that don't expose data.</h2>
        <p class="lead">
          These get a presence in OpenBurnBar — Installed / Not installed — but
          no usage rows. The vendor has to expose data for us to surface it.
        </p>
      </header>
      <ProviderTable rows={PROVIDERS_DETECTED} variant="compact" />
    </div>
  </section>

  <section class="provnotes">
    <div class="container container--narrow">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Caveats worth reading</span>
        <h2>Where it gets messy.</h2>
      </header>

      <ul class="caveats">
        <li>
          <h4>OpenAI &amp; Anthropic admin keys</h4>
          <p>
            Both use <em>org admin</em> keys (<code>sk-…</code> / <code>sk-ant-admin-…</code>), not regular API keys.
            Daily-granularity usage with ~24h vendor lag. We compute cost
            locally from a public pricing table — accurate for trends, not for tax audits.
          </p>
        </li>
        <li>
          <h4>Cursor &amp; Factory</h4>
          <p>
            Cursor's plan-usage and Factory's billing both rely on unofficial
            endpoints behind your authenticated session. Cursor's data is
            captured from the editor's local state DB; Factory uses a WorkOS browser
            session you complete via the in-app login helper. If the vendor changes
            shape, refresh breaks. We won't pretend it's covered by an SLA.
          </p>
        </li>
        <li>
          <h4>Z.ai endpoint</h4>
          <p>
            The BigModel <code>monitor/usage/quota/limit</code> endpoint is undocumented.
            It works today and returns clean numbers; the vendor can change it tomorrow.
          </p>
        </li>
        <li>
          <h4>Warp</h4>
          <p>
            Requires a spoofed <code>User-Agent</code> upstream — Warp's edge limiter
            returns 429 otherwise.
          </p>
        </li>
        <li>
          <h4>Gemini</h4>
          <p>
            Google AI Studio has no programmatic quota API. Per-session disk
            tokens exist on Gemini CLI; aggregate billing requires Vertex BigQuery
            exports, which we don't implement today.
          </p>
        </li>
        <li>
          <h4>Claude Code &amp; Codex stay self-hosted</h4>
          <p>
            Their real data sources live in your local filesystem. A cloud
            function has no lawful way to read them without an agent on your Mac.
            Plus, Anthropic's policy disallows third-party hosting of Claude.ai
            credentials — and we agree with that line.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <section class="endcta endcta--inline">
    <div class="container container--narrow">
      <h2>If your vendor is missing, file an issue.</h2>
      <p class="lead">
        We add providers when there's a real data source and a real user.
      </p>
      <div class="endcta__ctas">
        <a class="btn btn--ember" href="https://github.com/Imagine-That-Ai/BurnBar/issues" target="_blank" rel="noopener noreferrer">
          Open a GitHub issue <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn btn--ghost" href="https://github.com/Imagine-That-Ai/BurnBar/blob/main/docs/PROVIDERS.md" target="_blank" rel="noopener noreferrer">
          Read PROVIDERS.md
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pagehead { padding-block: var(--s-9) var(--s-6); }
  .pagehead__h { margin-top: var(--s-3); }
  .pagehead .lead { margin-top: var(--s-4); max-width: 60ch; }
  .legend {
    padding-block: var(--s-5) var(--s-7);
    border-block: 1px solid var(--ink-line);
  }
  .legend__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-4);
  }
  .legend__card {
    padding: var(--s-5);
    border: 1px solid var(--ink-line);
    border-radius: var(--r-4);
    background: var(--ink-base);
    display: grid;
    gap: var(--s-2);
  }
  .legend__card--exact { border-color: color-mix(in oklab, var(--status-exact) 22%, var(--ink-line)); }
  .legend__card--estimated { border-color: color-mix(in oklab, var(--status-estimated) 22%, var(--ink-line)); }
  .legend__card h3 {
    font-family: var(--font-display);
    color: var(--text-bright);
    font-size: 1.2rem;
    font-variation-settings: "opsz" 36, "wght" 500;
  }
  .legend__card p { color: var(--text-base); font-size: 0.92rem; }

  .sec-head { display: grid; gap: var(--s-3); margin-bottom: var(--s-6); max-width: 64ch; }
  .sec-head .lead { max-width: 60ch; }

  .detected {
    padding-block: var(--s-8);
    border-top: 1px solid var(--ink-line);
    background: var(--ink-base);
  }
  .provnotes {
    padding-block: var(--s-9);
    border-top: 1px solid var(--ink-line);
  }
  .caveats {
    display: grid;
    gap: var(--s-5);
  }
  .caveats li {
    padding: var(--s-5);
    border-left: 2px solid var(--ember-bright);
    background: var(--ink-base);
    border-radius: 0 var(--r-3) var(--r-3) 0;
  }
  .caveats h4 {
    font-family: var(--font-display);
    color: var(--text-bright);
    font-size: 1.05rem;
    margin-bottom: var(--s-2);
    font-variation-settings: "opsz" 36, "wght" 540;
  }
  .caveats p { color: var(--text-base); }

  @media (max-width: 880px) {
    .legend__grid { grid-template-columns: 1fr; }
  }

  .endcta--inline {
    padding-block: var(--s-9);
    text-align: center;
    background:
      radial-gradient(60% 80% at 50% 50%, rgba(255, 106, 26, 0.05), transparent 70%);
  }
  .endcta--inline h2 { margin-bottom: var(--s-3); }
  .endcta--inline .lead { margin: 0 auto; }
  .endcta__ctas { display: flex; justify-content: center; gap: var(--s-3); margin-top: var(--s-5); flex-wrap: wrap; }
</style>
