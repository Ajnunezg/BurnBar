---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProviderTable from "@components/ProviderTable.astro";
import {
  PROVIDERS_PRIMARY,
  PROVIDERS_DETECTED,
  CONFIDENCE_LABEL,
  CONFIDENCE_BLURB,
  type Confidence
} from "@data/providers";

const confidenceKeys: Confidence[] = ["exact", "estimated", "unavailable"];
---

<BaseLayout
  title="Providers"
  description="The honest provider support matrix for OpenBurnBar — Claude Code, Codex, OpenAI, Copilot, Cursor, Factory, MiniMax, Z.ai, Warp, Ollama, Kimi and more."
>
  <section class="pagehead">
    <div class="container pagehead__inner glass-pane">
      <span class="eyebrow eyebrow--ember">Providers</span>
      <h1 class="pagehead__h">An honest provider matrix.</h1>
      <p class="lead">
        Eleven providers ship with real usage data today. Eight more are detected
        but expose no usage API — we mark them so, rather than pretending.
        Confidence labels live on every row.
      </p>
    </div>
  </section>

  <section class="legend" aria-label="Confidence legend">
    <div class="container">
      <ol class="legend__grid">
        {confidenceKeys.map((k) => (
          <li class={`legend__card legend__card--${k} glass-pane`}>
            <header>
              <span class={`tag tag--plain mono tag--${k}`}>{k}</span>
            </header>
            <h3>{CONFIDENCE_LABEL[k]}</h3>
            <p>{CONFIDENCE_BLURB[k]}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ──────────── account-level routing preamble ──────────── -->
  <section class="accountrouting">
    <div class="container">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">How accounts route</span>
        <h2>One row per account. Routing is per-account, not per-provider.</h2>
        <p class="lead">
          Each row below is one account you add to BurnBar — not the vendor in
          the abstract. Add five Z.ai keys and you get five rows, five quota
          buckets, five spots in the router rotation. The matrix shows what
          BurnBar knows about each account; the router decides how to use them.
        </p>
      </header>

      <ul class="accountrouting__grid">
        <li class="accountrouting__card accountrouting__card--family glass-pane">
          <header>
            <span class="mono accountrouting__tag">model identity preserved</span>
            <h3>Failover only picks accounts that carry your exact model.</h3>
          </header>
          <p>
            Each row below lists which models that account carries.
            Failover only considers other rows that <strong>list the same model
            you asked for</strong> — MiniMax or Kimi only handle traffic for
            the models they actually carry, never a generic OpenAI-shape
            stand-in. The wire-format family (OpenAI-shape, Anthropic-shape)
            is the outer boundary; the model id is the inner one. If no row
            survives both filters, the gateway returns a structured 503 —
            never a stealth swap into a different model.
          </p>
        </li>
        <li class="accountrouting__card accountrouting__card--account glass-pane">
          <header>
            <span class="mono accountrouting__tag">account-level routing</span>
            <h3>Accounts have their own clocks and quotas.</h3>
          </header>
          <p>
            Each account keeps its own quota bucket, its own cool-down clock,
            its own LRU timestamp, and its own decision history. BurnBar will
            not collapse your accounts into a single generic pool. You added
            them separately because they cost differently, throttle
            differently, and recover differently — and the router treats them
            that way.
          </p>
        </li>
      </ul>

      <p class="accountrouting__cap mono">
        Want the policy in detail? · <a href="/router">read the router page</a>
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Real usage data · today</span>
        <h2>Eleven providers ship with live data.</h2>
        <p class="lead">
          Each one names exactly where data comes from, what we can know
          about cost, and how quota is shaped. Notes capture limitations
          we'd rather you read than discover later.
        </p>
      </header>
      <ProviderTable rows={PROVIDERS_PRIMARY} />
    </div>
  </section>

  <section class="detected">
    <div class="container">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Detection-only</span>
        <h2>Vendors that don't expose data.</h2>
        <p class="lead">
          These get a presence in OpenBurnBar — Installed / Not installed — but
          no usage rows. The vendor has to expose data for us to surface it.
        </p>
      </header>
      <ProviderTable rows={PROVIDERS_DETECTED} variant="compact" />
    </div>
  </section>

  <section class="provnotes">
    <div class="container container--narrow">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Caveats worth reading</span>
        <h2>Where it gets messy.</h2>
      </header>

      <ul class="caveats">
        <li>
          <h4>OpenAI &amp; Anthropic admin keys</h4>
          <p>
            Both use <em>org admin</em> keys (<code>sk-…</code> / <code>sk-ant-admin-…</code>), not regular API keys.
            Daily-granularity usage with ~24h vendor lag. We compute cost
            locally from a public pricing table — accurate for trends, not for tax audits.
          </p>
        </li>
        <li>
          <h4>Cursor &amp; Factory</h4>
          <p>
            Cursor's plan-usage and Factory's billing both rely on unofficial
            endpoints behind your authenticated session. Cursor's data is
            captured from the editor's local state DB; Factory uses a WorkOS browser
            session you complete via the in-app login helper. If the vendor changes
            shape, refresh breaks. We won't pretend it's covered by an SLA.
          </p>
        </li>
        <li>
          <h4>Z.ai endpoint</h4>
          <p>
            The BigModel <code>monitor/usage/quota/limit</code> endpoint is undocumented.
            It works today and returns clean numbers; the vendor can change it tomorrow.
          </p>
        </li>
        <li>
          <h4>Warp</h4>
          <p>
            Requires a spoofed <code>User-Agent</code> upstream — Warp's edge limiter
            returns 429 otherwise.
          </p>
        </li>
        <li>
          <h4>Gemini</h4>
          <p>
            Google AI Studio has no programmatic quota API. Per-session disk
            tokens exist on Gemini CLI; aggregate billing requires Vertex BigQuery
            exports, which we don't implement today.
          </p>
        </li>
        <li>
          <h4>Claude Code &amp; Codex stay self-hosted</h4>
          <p>
            Their real data sources live in your local filesystem. A cloud
            function has no lawful way to read them without an agent on your Mac.
            Plus, Anthropic's policy disallows third-party hosting of Claude.ai
            credentials — and we agree with that line.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <section class="endcta endcta--inline">
    <div class="container container--narrow endcta__inner glass-pane">
      <h2>If your vendor is missing, file an issue.</h2>
      <p class="lead">
        We add providers when there's a real data source and a real user.
      </p>
      <div class="endcta__ctas">
        <a class="btn btn--ember" href="https://github.com/Imagine-That-Ai/BurnBar/issues" target="_blank" rel="noopener noreferrer">
          Open a GitHub issue <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn btn--ghost" href="https://github.com/Imagine-That-Ai/BurnBar/blob/main/docs/PROVIDERS.md" target="_blank" rel="noopener noreferrer">
          Read PROVIDERS.md
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pagehead { padding-block: var(--s-9) var(--s-6); }
  .pagehead__inner {
    padding: var(--s-7) var(--s-6);
    border-radius: var(--r-xl);
    max-width: 960px;
    margin: 0 auto;
  }
  .pagehead__h { margin-top: var(--s-3); }
  .pagehead .lead { margin-top: var(--s-4); max-width: 60ch; }
  .legend {
    padding-block: var(--s-5) var(--s-7);
    border-block: 1px solid var(--ink-line);
  }
  .legend__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-4);
  }
  .legend__card {
    padding: var(--s-5);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--r-4);
    background: rgba(10, 10, 15, 0.72);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.45);
    display: grid;
    gap: var(--s-2);
  }
  .legend__card--exact { border-color: color-mix(in oklab, var(--status-exact) 22%, rgba(255, 255, 255, 0.08)); border-top-color: color-mix(in oklab, var(--status-exact) 35%, rgba(255, 255, 255, 0.16)); }
  .legend__card--estimated { border-color: color-mix(in oklab, var(--status-estimated) 22%, rgba(255, 255, 255, 0.08)); border-top-color: color-mix(in oklab, var(--status-estimated) 35%, rgba(255, 255, 255, 0.16)); }
  .legend__card h3 {
    font-family: var(--font-display);
    color: var(--text-bright);
    font-size: 1.2rem;
    font-variation-settings: "opsz" 36, "wght" 500;
  }
  .legend__card p { color: var(--text-base); font-size: 0.92rem; }

  .sec-head { display: grid; gap: var(--s-3); margin-bottom: var(--s-6); max-width: 64ch; }
  .sec-head .lead { max-width: 60ch; }

  .detected {
    padding-block: var(--s-8);
    border-top: 1px solid var(--ink-line);
    background: var(--ink-base);
  }
  .provnotes {
    padding-block: var(--s-9);
    border-top: 1px solid var(--ink-line);
  }
  .caveats {
    display: grid;
    gap: var(--s-5);
  }
  .caveats li {
    padding: var(--s-5);
    border-left: 3px solid var(--ember-bright);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(15, 10, 10, 0.72);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
    border-radius: 0 var(--r-3) var(--r-3) 0;
  }
  .caveats h4 {
    font-family: var(--font-display);
    color: var(--text-bright);
    font-size: 1.05rem;
    margin-bottom: var(--s-2);
    font-variation-settings: "opsz" 36, "wght" 540;
  }
  .caveats p { color: var(--text-base); }

  @media (max-width: 880px) {
    .legend__grid { grid-template-columns: 1fr; }
  }

  .endcta--inline {
    padding-block: var(--s-9);
    text-align: center;
    background:
      radial-gradient(60% 80% at 50% 50%, rgba(255, 106, 26, 0.05), transparent 70%);
  }
  .endcta--inline h2 { margin-bottom: var(--s-3); }
  .endcta--inline .lead { margin: 0 auto; }
  .endcta__ctas { display: flex; justify-content: center; gap: var(--s-3); margin-top: var(--s-5); flex-wrap: wrap; }
  .endcta__inner {
    text-align: center;
    display: grid;
    gap: var(--s-5);
    justify-items: center;
    padding: var(--s-7) var(--s-6);
  }

  /* ─── account routing preamble ─── */
  .accountrouting {
    padding-block: var(--s-8) var(--s-7);
    border-top: 1px solid var(--ink-line);
    background:
      radial-gradient(60% 50% at 10% 0%, rgba(255, 106, 26, 0.04), transparent 70%);
  }
  .accountrouting .sec-head { max-width: 68ch; }
  .accountrouting__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
    list-style: none;
  }
  .accountrouting__card {
    display: grid;
    gap: var(--s-3);
    padding: var(--s-5);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--r-4);
    background: rgba(10, 10, 15, 0.72);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.45);
  }
  .accountrouting__card--family {
    border-color: color-mix(in oklab, var(--ember-core) 30%, rgba(255, 255, 255, 0.08));
    border-top-color: color-mix(in oklab, var(--ember-core) 45%, rgba(255, 255, 255, 0.16));
  }
  .accountrouting__card--account {
    border-color: color-mix(in oklab, var(--mercury-bright) 24%, rgba(255, 255, 255, 0.08));
    border-top-color: color-mix(in oklab, var(--mercury-bright) 38%, rgba(255, 255, 255, 0.16));
  }
  .accountrouting__card header {
    display: grid;
    gap: var(--s-2);
  }
  .accountrouting__card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--text-bright);
    font-variation-settings: "opsz" 36, "wght" 540;
    letter-spacing: -0.014em;
    line-height: 1.18;
    text-wrap: balance;
  }
  .accountrouting__tag {
    color: var(--ember-bright);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: inline-block;
    width: max-content;
    padding: 1px 8px;
    border-radius: var(--r-pill);
    border: 1px solid color-mix(in oklab, var(--ember-core) 35%, var(--ink-line));
    background: color-mix(in oklab, var(--ember-core) 8%, transparent);
  }
  .accountrouting__card--account .accountrouting__tag {
    color: var(--mercury-bright);
    border-color: color-mix(in oklab, var(--mercury-bright) 32%, var(--ink-line));
    background: color-mix(in oklab, var(--mercury-bright) 8%, transparent);
  }
  .accountrouting__card p {
    color: var(--text-base);
    font-size: 0.94rem;
    line-height: 1.55;
  }
  .accountrouting__cap {
    margin-top: var(--s-5);
    padding-top: var(--s-3);
    border-top: 1px dashed var(--ink-line-soft);
    color: var(--text-dim);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }
  .accountrouting__cap a {
    color: var(--ember-bright);
  }
  @media (max-width: 880px) {
    .accountrouting__grid { grid-template-columns: 1fr; }
  }
</style>
