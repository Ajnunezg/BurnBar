---
import BaseLayout from "@layouts/BaseLayout.astro";
import Accordion from "@components/Accordion.astro";
import { FAQ } from "@data/faq";
import { SITE } from "@data/site";

// FAQ schema JSON-LD
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQ.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer.replace(/\n+/g, " ")
    }
  }))
};
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions about OpenBurnBar — data handling, accounts, API keys, cost accuracy, provider support, hosted quota sync, deletion, offline."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqLd)} />

  <section class="pagehead">
    <div class="container">
      <span class="eyebrow eyebrow--ember">FAQ</span>
      <h1 class="pagehead__h">Questions, answered.</h1>
      <p class="lead">
        The questions we hear most. Each one points back at the architecture choice that drove the
        answer. If the answer you need isn't here, open an issue.
      </p>
    </div>
  </section>

  <section class="faqsec">
    <div class="container container--narrow">
      <Accordion items={FAQ} open={FAQ[0]?.id} />
    </div>
  </section>

  <section class="moremore">
    <div class="container container--narrow">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Still curious</span>
        <h2>The docs that back this up.</h2>
      </header>
      <ul class="moremore__list">
        <li>
          <a
            href={`${SITE.github}/blob/main/docs/MISSION.md`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <strong>MISSION.md</strong>
            <span>The why, in the team's own words.</span>
          </a>
        </li>
        <li>
          <a
            href={`${SITE.github}/blob/main/docs/PROVIDERS.md`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <strong>PROVIDERS.md</strong>
            <span>The canonical provider table.</span>
          </a>
        </li>
        <li>
          <a
            href={`${SITE.github}/blob/main/docs/PRIVACY.md`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <strong>PRIVACY.md</strong>
            <span>Every byte that does or doesn't leave your machine.</span>
          </a>
        </li>
        <li>
          <a
            href={`${SITE.github}/blob/main/docs/THREAT_MODEL.md`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <strong>THREAT_MODEL.md</strong>
            <span>What we defend against and what we don't pretend.</span>
          </a>
        </li>
        <li>
          <a
            href={`${SITE.github}/blob/main/docs/HOSTED_QUOTA_SYNC.md`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <strong>HOSTED_QUOTA_SYNC.md</strong>
            <span>Why hosted quota sync exists and how it's verified.</span>
          </a>
        </li>
        <li>
          <a
            href={`${SITE.github}/blob/main/CHANGELOG.md`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <strong>CHANGELOG.md</strong>
            <span>Everything that's landed, in chronological order.</span>
          </a>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .pagehead {
    padding-block: var(--s-9) var(--s-6);
  }
  .pagehead__h {
    margin-top: var(--s-3);
  }
  .pagehead .lead {
    margin-top: var(--s-4);
    max-width: 60ch;
  }
  .faqsec {
    padding-block: var(--s-6) var(--s-9);
    border-top: 1px solid var(--ink-line);
  }
  .moremore {
    padding-block: var(--s-9);
    border-top: 1px solid var(--ink-line);
  }
  .sec-head {
    display: grid;
    gap: var(--s-3);
    margin-bottom: var(--s-6);
    max-width: 64ch;
  }
  .moremore__list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-3);
  }
  .moremore__list a {
    display: grid;
    gap: 4px;
    padding: var(--s-4);
    border: 1px solid var(--ink-line);
    border-radius: var(--r-3);
    background: var(--ink-base);
    color: var(--text-base);
    transition: border-color var(--dur-base) var(--ease-out);
  }
  .moremore__list a:hover {
    border-color: color-mix(in oklab, var(--ember-core) 40%, var(--ink-line));
  }
  .moremore__list strong {
    font-family: var(--font-mono);
    color: var(--text-bright);
    font-size: 0.95rem;
  }
  .moremore__list span {
    font-size: 0.88rem;
    color: var(--text-mute);
  }
  @media (max-width: 720px) {
    .moremore__list {
      grid-template-columns: 1fr;
    }
  }
</style>
