---
import BaseLayout from "@layouts/BaseLayout.astro";
import RouterSwitchboard from "@components/RouterSwitchboard.astro";
import RouterUseCases from "@components/RouterUseCases.astro";
import { SITE } from "@data/site";
---

<BaseLayout
  title="Fire Hydrant — the router"
  description="OpenBurnBar's local router runs in two modes: Provider-Family Failover (default) keeps your intent — Codex stays on OpenAI-family accounts, Claude Code stays on Anthropic-family — and extends capacity across multiple accounts in the same family. Intelligent Model Router (opt-in) scores task intent against model capability, quota, cost, latency, reliability, and benchmark freshness."
>
  <section class="pagehead">
    <div class="container">
      <span class="eyebrow eyebrow--ember">Fire Hydrant · the router</span>
      <h1 class="pagehead__h">
        Route by intent.
        <span class="ember">Fail over by family.</span>
      </h1>
      <p class="lead">
        BurnBar can keep you on the account you selected, fail over only within
        the same provider family when needed, or intelligently choose the best
        model when you enable smart routing. <strong>Provider-family mode protects
        your intent.</strong> <strong>Intelligent mode optimizes the route.</strong>
        Benchmarks inform the decision — but user choice, auth, quota, and
        availability win.
      </p>
      <div class="pagehead__ctas">
        <a class="btn btn--ember" href="/download">Download for macOS <span class="btn-arrow" aria-hidden="true">→</span></a>
        <a class="btn btn--ghost" href={`${SITE.github}/blob/main/docs/ROUTED_CLIENT_GATEWAY.md`} target="_blank" rel="noopener noreferrer">Read the gateway doc</a>
      </div>

      <ul class="pagehead__chips mono" aria-label="Quick highlights">
        <li><span class="dot dot--ember"></span> 127.0.0.1:8317 · local-only</li>
        <li><span class="dot dot--ember"></span> two modes · one daemon</li>
        <li><span class="dot dot--mercury"></span> benchmarks advisory · never absolute</li>
      </ul>
    </div>
  </section>

  <!-- ──────────── two modes — the headline framing ──────────── -->
  <section class="modes">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Two modes · one switch</span>
        <h2>Pick a mode like you pick a posture.</h2>
        <p class="lead">
          Most days you want the router to honor what you asked for and only
          quietly stretch capacity behind the scenes. Some days you'd rather it
          look at the task in front of you and pick the right tool. Same
          gateway. Same accounts. Different posture.
        </p>
      </header>

      <div class="modes__grid">
        <article class="modecard modecard--family">
          <header>
            <span class="mono modecard__tag">01 · default</span>
            <h3 class="modecard__h">Provider-Family Failover.</h3>
            <p class="modecard__sub mono">protects your intent · extends your capacity</p>
          </header>

          <p class="modecard__lede">
            You picked Codex. You get Codex's family. We extend capacity across
            <em>multiple accounts inside that family</em> — never across the
            boundary into Anthropic-shape models. If one Z.ai key throttles,
            the next OpenAI-family key picks up. Claude Code stays on Claude
            accounts. Codex stays on OpenAI-family accounts.
          </p>

          <svg class="modecard__diagram" viewBox="0 0 360 130" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Diagram: Codex request fanning out across OpenAI-family accounts only">
            <defs>
              <linearGradient id="fmRail" x1="0" x2="1" y1="0" y2="0">
                <stop offset="0%" stop-color="#ff6a1a" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#ffb547" stop-opacity="0.85"/>
              </linearGradient>
            </defs>
            <rect x="2" y="2" width="356" height="126" rx="14" fill="transparent" stroke="#2a2030"/>

            <g transform="translate(20, 18)">
              <rect width="86" height="22" rx="4" fill="#1a1422" stroke="#ff6a1a" stroke-opacity="0.55"/>
              <text x="43" y="15" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#ffb547">Codex CLI</text>
            </g>

            <g transform="translate(20, 50)">
              <rect width="86" height="22" rx="4" fill="#1a1422" stroke="#ff6a1a" stroke-opacity="0.55"/>
              <text x="43" y="15" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#ffb547">Forge</text>
            </g>

            <g transform="translate(20, 82)">
              <rect width="86" height="22" rx="4" fill="#1a1422" stroke="#ff6a1a" stroke-opacity="0.55"/>
              <text x="43" y="15" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#ffb547">Cursor BYOK</text>
            </g>

            <path d="M 110 29 H 178 V 50 H 240" stroke="url(#fmRail)" stroke-width="1.5" fill="none"/>
            <path d="M 110 61 H 178 V 65 H 240" stroke="url(#fmRail)" stroke-width="1.5" fill="none"/>
            <path d="M 110 93 H 178 V 82 H 240" stroke="url(#fmRail)" stroke-width="1.5" fill="none"/>

            <g transform="translate(168, 50)">
              <rect width="22" height="30" rx="4" fill="#1a1422" stroke="#ff6a1a"/>
              <text x="11" y="15" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="6" fill="#ff8a3d">OBB</text>
              <text x="11" y="24" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="6" fill="#ff8a3d">8317</text>
            </g>

            <g transform="translate(238, 30)">
              <rect width="100" height="20" rx="4" fill="#0c0a0f" stroke="#ff6a1a"/>
              <text x="50" y="13" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#ffb547">Z.ai · active</text>
            </g>
            <g transform="translate(238, 56)">
              <rect width="100" height="20" rx="4" fill="#0c0a0f" stroke="#ffb547" stroke-opacity="0.55" stroke-dasharray="3 2"/>
              <text x="50" y="13" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#ffb547">MiniMax · fallback</text>
            </g>
            <g transform="translate(238, 82)">
              <rect width="100" height="20" rx="4" fill="#0c0a0f" stroke="#2a2030"/>
              <text x="50" y="13" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#8b8275">Kimi · healthy</text>
            </g>

            <text x="290" y="120" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="8" fill="#5c5448" letter-spacing="0.06em">OpenAI-family pool — same family only</text>
          </svg>

          <ul class="modecard__list">
            <li><strong>Single intent, many accounts.</strong> Pin Z.ai for GLM coding work, hold MiniMax and Kimi in reserve.</li>
            <li><strong>Same-format failover only.</strong> An OpenAI-shape request can only be served by an OpenAI-family account.</li>
            <li><strong>Pin sticks unless it can't.</strong> Your preferred account wins when healthy; the runner-up is already chosen.</li>
            <li><strong>Cool-downs auto-recover.</strong> Five-minute parking on transient failures, then the account rejoins the rotation.</li>
          </ul>

          <p class="modecard__when mono">use when · single coding intent · trusted account topology · no surprise model swaps</p>
        </article>

        <article class="modecard modecard--intelligent">
          <header>
            <span class="mono modecard__tag">02 · opt-in</span>
            <h3 class="modecard__h">Intelligent Model Router.</h3>
            <p class="modecard__sub mono">optimizes the route · benchmark-aware · still local</p>
          </header>

          <p class="modecard__lede">
            Tell BurnBar what the task is. Refactor a million-token diff. Draft a
            release note. Run a fast lint. The router scores every candidate
            model against the task and picks the one that fits — using
            capability, quota health, cost, latency, context window,
            reliability, and benchmark freshness as <em>advisory signals</em>.
          </p>

          <svg class="modecard__diagram" viewBox="0 0 360 130" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Diagram: task scored against multiple candidate models, winner picked">
            <defs>
              <linearGradient id="imRail" x1="0" x2="1" y1="0" y2="0">
                <stop offset="0%" stop-color="#d6d3df" stop-opacity="0.85"/>
                <stop offset="100%" stop-color="#aeacba" stop-opacity="0.8"/>
              </linearGradient>
            </defs>
            <rect x="2" y="2" width="356" height="126" rx="14" fill="transparent" stroke="#2a2030"/>

            <g transform="translate(20, 18)">
              <rect width="118" height="22" rx="4" fill="#1a1422" stroke="#d6d3df" stroke-opacity="0.4"/>
              <text x="59" y="15" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#d6d3df">task · refactor SQL</text>
            </g>

            <g transform="translate(20, 50)">
              <rect width="118" height="22" rx="4" fill="#1a1422" stroke="#d6d3df" stroke-opacity="0.4"/>
              <text x="59" y="15" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#d6d3df">ctx · 940k tokens</text>
            </g>

            <g transform="translate(20, 82)">
              <rect width="118" height="22" rx="4" fill="#1a1422" stroke="#d6d3df" stroke-opacity="0.4"/>
              <text x="59" y="15" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#d6d3df">budget · cost-tight</text>
            </g>

            <path d="M 142 29 H 180 V 65 H 200" stroke="url(#imRail)" stroke-width="1.5" fill="none"/>
            <path d="M 142 61 H 200" stroke="url(#imRail)" stroke-width="1.5" fill="none"/>
            <path d="M 142 93 H 180 V 65 H 200" stroke="url(#imRail)" stroke-width="1.5" fill="none"/>

            <g transform="translate(178, 50)">
              <circle cx="14" cy="14" r="12" fill="#0c0a0f" stroke="#d6d3df"/>
              <text x="14" y="11" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="5" fill="#d6d3df">score</text>
              <text x="14" y="20" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="5" fill="#d6d3df">+rank</text>
            </g>

            <path d="M 210 65 H 234" stroke="url(#imRail)" stroke-width="1.5" fill="none"/>

            <g transform="translate(236, 30)">
              <rect width="102" height="20" rx="4" fill="#0c0a0f" stroke="#d6d3df"/>
              <text x="51" y="13" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#d6d3df">opus-4-7 · pick</text>
            </g>
            <g transform="translate(236, 56)">
              <rect width="102" height="20" rx="4" fill="#0c0a0f" stroke="#aeacba" stroke-opacity="0.45" stroke-dasharray="3 2"/>
              <text x="51" y="13" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#aeacba">sonnet-4-6 · runner</text>
            </g>
            <g transform="translate(236, 82)">
              <rect width="102" height="20" rx="4" fill="#0c0a0f" stroke="#2a2030"/>
              <text x="51" y="13" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="9" fill="#8b8275">gpt-4.1 · skipped (ctx)</text>
            </g>

            <text x="295" y="120" text-anchor="middle" font-family="JetBrains Mono Variable, monospace" font-size="8" fill="#5c5448" letter-spacing="0.06em">scored every turn · explained every pick</text>
          </svg>

          <ul class="modecard__list">
            <li><strong>Score, don't guess.</strong> Each candidate model gets a per-task score; the router picks the winner and pre-selects a runner-up.</li>
            <li><strong>Benchmarks are advisory.</strong> Freshness matters. A 30-day-old benchmark is weighted less than a 3-day-old one.</li>
            <li><strong>User choice still wins.</strong> A pinned model that meets the floor beats a higher-scored model that doesn't.</li>
            <li><strong>Always explainable.</strong> Every pick streams a <span class="mono">decision_reason</span> you can inspect in the Router tab.</li>
          </ul>

          <p class="modecard__when mono">use when · cross-task variance · cost-sensitive work · researcher / scout / autopilot flows</p>
        </article>
      </div>

      <p class="modes__cap mono">
        Both modes run inside the same local gateway. Switch from the Router tab
        in the macOS app · no daemon restart · no config file edit.
      </p>
    </div>
  </section>

  <!-- ──────────── two pools ──────────── -->
  <section class="poolsec">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Two pools, same-format failover</span>
        <h2>Two highways, never crossed.</h2>
        <p class="lead">
          Tool-call schemas, prompt-cache markers, and streaming-event types
          differ enough between OpenAI Chat Completions and Anthropic Messages
          that "translating" between them quietly breaks things — citations
          go missing, tool calls misfire, cache markers drop. The Hydrant
          refuses that game. A request on one endpoint can only be served by
          accounts in that pool. Same-format failover. Provable in tests.
        </p>
      </header>

      <div class="poolsec__grid">
        <article class="poolcard poolcard--openai">
          <header>
            <span class="tag tag--ember tag--plain mono">OpenAI-family pool</span>
            <h3 class="poolcard__h">/v1/chat/completions</h3>
            <p class="poolcard__sub mono">OpenAI Chat Completions · SSE stream pass-through</p>
          </header>
          <ul class="poolcard__list">
            <li><strong>Clients:</strong> Cursor (BYOK tunnel), Factory, Forge, OpenCode, Codex CLI in API-key mode.</li>
            <li><strong>Upstream accounts:</strong> OpenAI, Z.ai, MiniMax, Kimi, Ollama Cloud, Ollama Local.</li>
            <li><strong>Failover trigger:</strong> 429, 401, 402, 403, "quota" / "rate" / "exhaust" in response body.</li>
            <li><strong>Empty-pool behaviour:</strong> 503 with a structured message naming the missing pool.</li>
          </ul>
        </article>

        <article class="poolcard poolcard--anthropic">
          <header>
            <span class="tag tag--mercury tag--plain mono">Anthropic-family pool</span>
            <h3 class="poolcard__h">/v1/messages</h3>
            <p class="poolcard__sub mono">Anthropic Messages · sk-ant via x-api-key · Bearer for OAuth</p>
          </header>
          <ul class="poolcard__list">
            <li><strong>Clients:</strong> Claude Code with <code class="poolcard__code">ANTHROPIC_BASE_URL</code> + <code class="poolcard__code">ANTHROPIC_AUTH_TOKEN</code>.</li>
            <li><strong>Upstream accounts:</strong> Anthropic Console (sk-ant-… admin key), Anthropic Pro/Team (OAuth bearer).</li>
            <li><strong>Auth-header dispatch:</strong> sk-ant-… → <code class="poolcard__code">x-api-key</code>; OAuth bearer → <code class="poolcard__code">Authorization</code>.</li>
            <li><strong>Anthropic version:</strong> pinned to <code class="poolcard__code">2023-06-01</code> on every request.</li>
          </ul>
        </article>
      </div>

      <p class="poolsec__cap mono">
        Source · <code>OpenBurnBarDaemon/.../OpenBurnBarHTTPGatewayServer.swift</code> · <code>OpenBurnBarAnthropicProviderExecutor.swift</code>
      </p>
    </div>
  </section>

  <!-- ──────────── live switchboard ──────────── -->
  <section class="routerboard">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">The board · family mode</span>
        <h2>What it looks like in practice.</h2>
        <p class="lead">
          The board mirrors the macOS app's <strong>Router</strong> tab. The
          mode strip shows which posture is active and the latest decision the
          router made. Pinned accounts carry a dashed ring. Active routes glow
          ember. Next-fallback waits in amber. Blocked routes spell out why.
        </p>
      </header>

      <RouterSwitchboard mode="family" />

      <header class="sec-head sec-head--mini routerboard__altcap">
        <span class="eyebrow eyebrow--mercury">The same board · intelligent mode</span>
        <h3 class="routerboard__h3">Different posture, same accounts, same wire.</h3>
      </header>

      <RouterSwitchboard mode="intelligent" />
    </div>
  </section>

  <!-- ──────────── how decisions are made ──────────── -->
  <section class="factors">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">How decisions are made</span>
        <h2>Nine signals, weighted by the mode you're in.</h2>
        <p class="lead">
          In family mode the first three weigh heaviest — they protect intent.
          In intelligent mode the full nine come into play. <strong>None of them
          is absolute.</strong> Benchmarks are the youngest source we trust;
          they're advisory signals, not gospel.
        </p>
      </header>

      <ol class="factors__grid">
        <li class="factor factor--anchor">
          <span class="mono factor__idx">01</span>
          <h3>Task intent</h3>
          <p>What you asked for. The pinned model, the chosen agent, the explicit "Codex" vs "Claude Code" surface — all hard constraints. Anything that violates intent is filtered out before scoring begins.</p>
        </li>
        <li class="factor factor--anchor">
          <span class="mono factor__idx">02</span>
          <h3>Model capability</h3>
          <p>Coding ability, reasoning depth, tool-use reliability, multimodal support, fine-grained instruction following. Read from a versioned capability matrix you can audit.</p>
        </li>
        <li class="factor factor--anchor">
          <span class="mono factor__idx">03</span>
          <h3>Quota health</h3>
          <p>Live read of the active bucket. Healthy outranks pressure; pressure outranks cooling-down; cooling-down outranks rate-limited; everything outranks exhausted and auth-failed.</p>
        </li>
        <li class="factor">
          <span class="mono factor__idx">04</span>
          <h3>Local availability</h3>
          <p>Is the credential on disk right now, or would the router have to fetch a hosted secret? Local credentials win — lower latency, smaller blast radius.</p>
        </li>
        <li class="factor">
          <span class="mono factor__idx">05</span>
          <h3>Cost</h3>
          <p>Per-token pricing for the candidate model on the candidate account, against the request size we can estimate. Tie-breaker between equally capable options.</p>
        </li>
        <li class="factor">
          <span class="mono factor__idx">06</span>
          <h3>Latency</h3>
          <p>Recent rolling median TTFB and tokens-per-second observed from <em>your</em> traffic on this account. Not vendor marketing — measured locally.</p>
        </li>
        <li class="factor">
          <span class="mono factor__idx">07</span>
          <h3>Context window</h3>
          <p>If the request needs 940k tokens of context, a 256k window is disqualified — never picked, never partially used. No silent truncation.</p>
        </li>
        <li class="factor">
          <span class="mono factor__idx">08</span>
          <h3>Reliability</h3>
          <p>Recent 5xx rate, stream-corruption rate, and tool-call success rate. An otherwise-perfect account that flakes 4% of the time is penalized accordingly.</p>
        </li>
        <li class="factor factor--mercury">
          <span class="mono factor__idx">09</span>
          <h3>Benchmark freshness <span class="factor__note mono">advisory</span></h3>
          <p>External coding benchmarks (Aider, LMSys, SWE-Bench refresh windows) feed in with an age penalty. A 3-day-old score weighs more than a 30-day-old one — and a benchmark never overrides your pin.</p>
        </li>
      </ol>

      <p class="factors__cap mono">
        The first three are hard constraints in both modes. The remaining six
        weigh into the score the router uses to rank survivors after the filter.
      </p>
    </div>
  </section>

  <!-- ──────────── what BurnBar will not do ──────────── -->
  <section class="wontdo">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--burn">What BurnBar will not do</span>
        <h2>The bright lines we don't cross.</h2>
        <p class="lead">
          A router that's allowed to do anything is a router you can't predict.
          These are the constraints baked into the policy — not promises, code.
        </p>
      </header>

      <ul class="wontdo__grid">
        <li class="wontno">
          <span class="wontno__x" aria-hidden="true">✕</span>
          <div>
            <h3>Will not send a Codex task to Claude in failover mode.</h3>
            <p>
              Family boundaries are enforced at the gateway. An OpenAI-shape request
              can only be served by an OpenAI-family account. The mode is honored
              <em>before</em> ranking — there's no fallback path that crosses the wire.
            </p>
          </div>
        </li>
        <li class="wontno">
          <span class="wontno__x" aria-hidden="true">✕</span>
          <div>
            <h3>Will not collapse your accounts into a generic quota pool.</h3>
            <p>
              Each account keeps its own quota, its own cool-down clock, its own
              decision history. You added them separately — the router treats them
              separately. No global "tokens left" number that hides which key is
              actually carrying load.
            </p>
          </div>
        </li>
        <li class="wontno">
          <span class="wontno__x" aria-hidden="true">✕</span>
          <div>
            <h3>Will not log secrets.</h3>
            <p>
              Decision logs record the account ID, the chosen model, the reasons
              other candidates were skipped — never the API key, never the OAuth
              bearer, never request bodies. Keys live in the macOS Keychain with
              device-local accessibility.
            </p>
          </div>
        </li>
        <li class="wontno">
          <span class="wontno__x" aria-hidden="true">✕</span>
          <div>
            <h3>Will not treat benchmarks as absolute truth.</h3>
            <p>
              Benchmarks help break ties, surface candidates, and weigh recency.
              They never veto your pin. They never trump live quota or auth state.
              A model that benchmarks two points higher but is rate-limited right
              now still loses.
            </p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ──────────── what is / isn't routed ──────────── -->
  <section class="scope">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">The honest scope</span>
        <h2>Routed today vs. tracked today.</h2>
        <p class="lead">
          Some providers are routed through the Hydrant — your request lands at
          OpenBurnBar's local gateway and gets forwarded. Others are
          <em>tracked</em> for cost and quota only — we read the dashboard, we
          don't proxy the inference. Both are useful. Only the routed ones
          benefit from automatic failover today.
        </p>
      </header>

      <div class="scope__grid">
        <article class="scopecard scopecard--routed">
          <header>
            <span class="tag tag--exact tag--plain mono">Routed today — 7 upstreams</span>
            <h3>Inference goes through the Hydrant.</h3>
          </header>
          <ul class="scope__list">
            <li>
              <img src="/brand/providers/openai.png" alt="" width="28" height="28" loading="lazy" />
              <div><strong>OpenAI</strong><span>API-key routing; OpenAI-family pool. Pay-as-you-go fallback for Codex.</span></div>
            </li>
            <li>
              <img src="/brand/providers/zai.png" alt="" width="28" height="28" loading="lazy" />
              <div><strong>Z.ai (GLM)</strong><span>Coding Plan keys; OpenAI-family pool. Token + MCP quota live.</span></div>
            </li>
            <li>
              <img src="/brand/providers/minimax.png" alt="" width="28" height="28" loading="lazy" />
              <div><strong>MiniMax</strong><span>Coding-plan keys (sk-cp-…); OpenAI-family pool. Per-model remaining quota.</span></div>
            </li>
            <li>
              <img src="/brand/providers/kimi.png" alt="" width="28" height="28" loading="lazy" />
              <div><strong>Kimi (Moonshot)</strong><span>OpenAI-compatible endpoint; OpenAI-family pool. Weekly token window.</span></div>
            </li>
            <li>
              <img src="/brand/providers/ollama.png" alt="" width="28" height="28" loading="lazy" />
              <div><strong>Ollama Cloud + Local</strong><span>Both routed in the OpenAI-family pool. Local cloud-suffix aliases rewritten before upstream.</span></div>
            </li>
            <li>
              <img src="/brand/providers/anthropic.png" alt="" width="28" height="28" loading="lazy" />
              <div><strong>Anthropic Console + Pro/Team</strong><span>Anthropic-family pool. sk-ant-… via x-api-key, OAuth bearer via Authorization.</span></div>
            </li>
          </ul>
          <p class="scope__cap mono">
            Source · <code>catalog.json</code> · <code>ProviderAccountTypes.swift:403-599</code>
          </p>
        </article>

        <article class="scopecard scopecard--tracked">
          <header>
            <span class="tag tag--estimated tag--plain mono">Tracked-only today</span>
