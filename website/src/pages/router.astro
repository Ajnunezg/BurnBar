---
import BaseLayout from "@layouts/BaseLayout.astro";
import LockedModelRelay from "@components/LockedModelRelay.astro";
import RuleVignette from "@components/RuleVignette.astro";
import ModeComparison from "@components/ModeComparison.astro";
import TodaysRundown from "@components/TodaysRundown.astro";
import LifecycleStateMachine from "@components/LifecycleStateMachine.astro";
import PlatformShowcase from "@components/platform/PlatformShowcase.astro";
import { SITE } from "@data/site";

const faqEntries = [
  {
    q: "Will failover ever change my model?",
    a: "No. Failover stays inside the model identity you asked for. If you sent `gpt-5.5`, the router will only pick from accounts whose catalog also carries `gpt-5.5`. If no eligible account exists, BurnBar returns a structured 503 — never a silent substitute."
  },
  {
    q: "What is Provider-Family Failover?",
    a: "The default mode. BurnBar extends capacity for the same model across multiple accounts inside the same wire-format family. If your pinned key throttles, any account in your library that ALSO carries that model picks up — never a different model."
  },
  {
    q: "What is the Intelligent Model Router?",
    a: "The opt-in mode. You tell BurnBar what the task is; a daily board of language models researches the model landscape, and deterministic policy turns that work into a stable shortlist. Benchmarks are advisory; pins and quota always win."
  },
  {
    q: "What benchmark sources does BurnBar use?",
    a: "Artificial Analysis (intelligence + coding indices · pricing · TPS), Terminal-Bench via Hugging Face (verified shell-loop agents), and Design Arena (pairwise Elo). Manual cached fixtures cover gaps. Every signal carries a freshness state — fresh / stale / unavailable / error / manual — surfaced in `/router/daily`."
  },
  {
    q: "Can I pin a model in either mode?",
    a: "Yes. In Provider-Family Failover, you pin an account; the runner-up is pre-selected. In Intelligent Mode, you can pin a model, a family, or a tier (e.g. \"always opus-class for autopilot\"). A healthy pin always wins."
  },
  {
    q: "Are routing logs safe?",
    a: "Yes. The local `ProviderRoutingDecisionEvent` stream records the chosen account ID, the skipped account IDs, and the reason each was skipped — never API keys, OAuth bearers, request bodies, or response bodies. Logs stay in the local SQLite store."
  }
];
---

<BaseLayout
  title="The router — same model, every time"
  description="BurnBar's local router preserves the exact model you asked for. Failover swaps accounts, never the model. Intelligent mode uses a daily board of language models to research candidates against Artificial Analysis, Terminal-Bench, and Design Arena — benchmarks advisory, pins always win."
>
  <section class="pagehead" aria-labelledby="hero-h">
    <div class="container container--wide pagehead__inner glass-pane">
      <span class="eyebrow eyebrow--ember">The router · same-model · animated</span>
      <h1 id="hero-h" class="pagehead__h">
        Same model.
        <span class="pagehead__hb">Different account.</span>
        <span class="pagehead__hsm">Every time.</span>
      </h1>
      <p class="pagehead__lead">
        BurnBar's local router stretches one model across every account in
        your library that serves it. Your <code class="mono">gpt-5.5</code> stays
        <code class="mono">gpt-5.5</code>. Your
        <code class="mono">claude-opus-4-7</code> stays
        <code class="mono">claude-opus-4-7</code>. The accounts swap;
        the model never does.
      </p>

      <ul class="pagehead__chips mono" aria-label="Quick highlights">
        <li><span class="dot dot--ember"></span> 127.0.0.1:8317 · local-only</li>
        <li><span class="dot dot--ember"></span> two modes · one daemon</li>
        <li><span class="dot dot--mercury"></span> daily model board · pins win</li>
      </ul>

      <div class="pagehead__visual">
        <LockedModelRelay variant="big" modelID="gpt-5.5" modelTag="model id · invariant" />
      </div>

      <div class="pagehead__ctas">
        <a class="btn btn--ember" href="/download">Download for macOS <span class="btn-arrow" aria-hidden="true">→</span></a>
        <a class="btn btn--ghost" href={`${SITE.github}/blob/main/docs/ROUTED_CLIENT_GATEWAY.md`} target="_blank" rel="noopener noreferrer">Read the gateway doc</a>
        <a class="btn btn--ghost" href="/router/daily">See today's rundown</a>
      </div>
    </div>
  </section>

  {/* ──────────────── 2 · NON-NEGOTIABLE RULE ──────────────── */}
  <section class="rules" aria-labelledby="rules-h">
    <div class="container container--wide">
      <header class="rules__head">
        <span class="eyebrow eyebrow--ember">The non-negotiable rule</span>
        <h2 id="rules-h" class="rules__h">Your model in. Your model out. Every path.</h2>
        <p class="rules__lead">
          Three things can happen to a request in flight. Watch what each one
          does — or refuses to do — to the model identity you asked for.
        </p>
      </header>

      <div class="rules__grid">
        <RuleVignette
          idx={1}
          variant="swap-account"
          model="gpt-5.5"
          title="Primary OpenAI key throttled → backup OpenAI key, same model."
          eyebrow="01 · gpt-5.5 · 429"
          client={{ name: "Forge", logo: "/brand/providers/forge.png" }}
          primary={{ name: "OpenAI · personal", logo: "/brand/providers/openai.png", state: "primary" }}
          fallback={{ name: "Codex · plus", logo: "/brand/providers/codex.png", state: "carries gpt-5.5" }}
          failure="429"
          swapDetail="account only · gpt-5.5 → gpt-5.5"
        />

        <RuleVignette
          idx={2}
          variant="swap-auth"
          model="claude-opus-4-7"
          title="Pro plan capped → Console admin key, same model."
          eyebrow="02 · claude-opus-4-7"
          client={{ name: "Claude Code", logo: "/brand/providers/claude-code.png" }}
          primary={{ name: "Anthropic Pro", logo: "/brand/providers/anthropic.png", state: "5h cap hit", auth: "OAuth bearer" }}
          fallback={{ name: "Console admin", logo: "/brand/providers/anthropic.png", state: "healthy", auth: "x-api-key" }}
          failure="5h · cap"
          swapDetail="Authorization → x-api-key · same model id on the wire"
        />

        <RuleVignette
          idx={3}
          variant="no-fallback"
          model="glm-4.6"
          title="No other account carries it → 503, never a swap."
          eyebrow="03 · glm-4.6 · 503"
          client={{ name: "Cursor", logo: "/brand/providers/cursor.png" }}
          primary={{ name: "Z.ai", logo: "/brand/providers/zai.png", state: "exhausted" }}
          fallback={null}
          failure="exhausted · last carrier"
          swapDetail="nothing — gate closes, IDE sees a clean 503"
        />
      </div>

      <p class="rules__cap mono">
        Implementation · <code>ProviderRoutingPolicy.decide</code> @
        <code>ProviderAccountTypes.swift:735</code> ·
        gate response @ <code>OpenBurnBarHTTPGatewayServer.swift:361</code>
      </p>
    </div>
  </section>

  {/* ──────────────── 3 · TWO MODES ──────────────── */}
  <div class="container container--wide">
    <ModeComparison />
  </div>

  {/* ──────────────── 4 · TODAY'S RUNDOWN ──────────────── */}
  <div class="container container--wide" id="daily-rundown">
    <TodaysRundown />
  </div>

  {/* ──────────────── 4.5 · SMART DISPLAY MOCKUPS (live re-renders) ──────────────── */}
  <PlatformShowcase variant="compact" />

  {/* ──────────────── 5 · WHAT BURNBAR WILL NOT DO ──────────────── */}
  <section class="wontdo" aria-labelledby="wontdo-h">
    <div class="container container--wide">
      <header class="wontdo__head">
        <span class="eyebrow eyebrow--burn">What BurnBar will not do</span>
        <h2 id="wontdo-h" class="wontdo__h">Four bright lines we don't cross.</h2>
        <p class="wontdo__lead">
          A router that's allowed to do anything is a router you can't predict.
          These are baked into the policy — not promises, code.
        </p>
      </header>

      <ul class="wontdo__grid" role="list">
        <li class="wontno wontno--headline">
          <span class="wontno__x" aria-hidden="true">✕</span>
          <div>
            <h3 class="wontno__h">Will not swap your model on failover.</h3>
            <p>
              Filter rule #F in <code class="mono">ProviderRoutingPolicy.decide</code> drops every candidate account whose model catalog doesn't list your requested model. If no candidate survives, the gateway returns a structured 503 — your IDE sees a clean error, never a silent substitute.
            </p>
          </div>
        </li>
        <li class="wontno">
          <span class="wontno__x" aria-hidden="true">✕</span>
          <div>
            <h3 class="wontno__h">Will not collapse accounts into a generic quota pool.</h3>
            <p>
              Each account keeps its own bucket, its own cool-down clock, its own decision history. You added them separately because they cost and throttle differently — the router treats them that way.
            </p>
          </div>
        </li>
        <li class="wontno">
          <span class="wontno__x" aria-hidden="true">✕</span>
          <div>
            <h3 class="wontno__h">Will not log secrets.</h3>
            <p>
              The local decision stream records the chosen account ID, the skipped ones, and the reason each was skipped. It never records the API key, the OAuth bearer, the request body, or the response body. Keys live in the macOS Keychain, device-local.
            </p>
          </div>
        </li>
        <li class="wontno">
          <span class="wontno__x" aria-hidden="true">✕</span>
          <div>
            <h3 class="wontno__h">Will not treat benchmarks as absolute truth.</h3>
            <p>
              Benchmark snapshots feed the daily model board and inform deterministic selection. They never override a pin. They never beat live quota state. A model that benchmarks higher but is rate-limited right now still loses.
            </p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  {/* ──────────────── 6 · LIFECYCLE ──────────────── */}
  <div class="container container--wide">
    <LifecycleStateMachine />
  </div>

  {/* ──────────────── 7 · FAQ ──────────────── */}
  <section class="qa" aria-labelledby="qa-h">
    <div class="container container--wide">
      <header class="qa__head">
        <span class="eyebrow eyebrow--ember">Quick answers</span>
        <h2 id="qa-h" class="qa__h">The questions we get on every demo.</h2>
      </header>

      <dl class="qa__list">
        {faqEntries.map((entry) => (
          <div class="qa__item glass-pane">
            <dt>{entry.q}</dt>
            <dd set:html={entry.a.replace(/`([^`]+)`/g, "<code class='mono'>$1</code>")} />
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="endcta endcta--inline">
    <div class="container container--narrow endcta__inner glass-pane">
      <h2>Pin a model. Add a second account. Sleep on it.</h2>
      <p class="lead">
        BurnBar keeps your model — and your work — running across whatever
        account is healthy right now.
      </p>
      <div class="endcta__ctas">
        <a class="btn btn--ember" href="/download">Download for macOS <span class="btn-arrow" aria-hidden="true">→</span></a>
        <a class="btn btn--ghost" href={`${SITE.github}/blob/main/docs/ROUTED_CLIENT_GATEWAY.md`} target="_blank" rel="noopener noreferrer">Read the gateway doc</a>
        <a class="btn btn--ghost" href="/router/daily">Browse the daily rundown</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import "../scripts/animateOnView";
</script>

<style>
  /* ────────── 1. HERO ────────── */
  .pagehead { padding-block: var(--s-9) var(--s-7); }
  .pagehead__inner {
    display: grid;
    gap: var(--s-5);
    justify-items: center;
    text-align: center;
    padding: var(--s-7) var(--s-6);
    border-radius: var(--r-xl);
  }
  .pagehead__h {
    margin-top: var(--s-2);
    max-width: 22ch;
    text-wrap: balance;
    font-size: clamp(2.4rem, 1.6rem + 3vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--text-bright);
    font-variation-settings: "opsz" 144, "wght" 460;
  }
  .pagehead__hb {
    display: block;
    color: var(--ember-bright);
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 360, "ital" 1;
  }
  .pagehead__hsm {
    display: block;
    color: var(--text-mute);
    font-variation-settings: "opsz" 80, "wght" 380;
    font-size: 0.52em;
    letter-spacing: 0.02em;
    margin-top: 0.4em;
  }
  .pagehead__lead {
    color: var(--text-base);
    max-width: 60ch;
    margin: 0 auto;
    font-size: var(--t-lead);
    line-height: 1.5;
  }
  .pagehead__lead code {
    color: var(--ember-bright);
    background: var(--ink-surface);
    padding: 1px 6px;
    border-radius: var(--r-2);
    border: 1px solid var(--ink-line);
  }
  .pagehead__chips {
    list-style: none;
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--s-3) var(--s-5);
    padding: var(--s-3) var(--s-4);
    border: 1px dashed var(--ink-line);
    border-radius: var(--r-pill);
    font-size: var(--t-caption);
    color: var(--text-mute);
    letter-spacing: 0.03em;
    background: color-mix(in oklab, var(--ink-surface) 60%, transparent);
    margin: 0;
  }
  .pagehead__chips li { display: inline-flex; align-items: center; gap: var(--s-2); }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot--ember   { background: var(--ember-core); box-shadow: 0 0 8px var(--ember-glow); }
  .dot--mercury { background: var(--mercury-bright); box-shadow: 0 0 8px color-mix(in oklab, var(--mercury-bright) 55%, transparent); }
  .pagehead__visual {
    width: 100%;
    max-width: 980px;
    margin: var(--s-3) auto 0;
  }
  .pagehead__ctas {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--s-3);
  }

  /* ────────── 2. RULES ────────── */
  .rules {
    padding-block: var(--s-9);
    border-top: 1px solid var(--ink-line);
    background:
      radial-gradient(70% 50% at 50% 0%, rgba(255, 106, 26, 0.05), transparent 65%);
  }
  .rules__head {
    max-width: 64ch;
    margin: 0 auto var(--s-6);
    text-align: center;
    display: grid;
    gap: var(--s-3);
  }
  .rules__h {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.4rem);
    color: var(--text-bright);
    font-variation-settings: "opsz" 80, "wght" 500;
    letter-spacing: -0.022em;
    text-wrap: balance;
  }
  .rules__lead { color: var(--text-base); max-width: 56ch; margin: 0 auto; line-height: 1.55; }
  .rules__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-4);
  }
  @media (max-width: 1080px) { .rules__grid { grid-template-columns: 1fr; max-width: 560px; margin-inline: auto; } }
  .rules__cap {
    margin-top: var(--s-5);
    color: var(--text-dim);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-align: center;
  }
  .rules__cap code {
    color: var(--text-mute);
    background: var(--ink-base);
    padding: 1px 6px;
    border-radius: var(--r-2);
    border: 1px solid var(--ink-line);
  }

  /* ────────── 5. WONT DO ────────── */
  .wontdo {
    padding-block: var(--s-9);
    border-top: 1px solid var(--ink-line);
    background:
      radial-gradient(60% 50% at 0% 0%, rgba(229, 72, 60, 0.04), transparent 70%);
  }
  .wontdo__head {
    max-width: 64ch;
    margin: 0 auto var(--s-6);
    text-align: center;
    display: grid;
    gap: var(--s-3);
  }
  .wontdo__head .eyebrow { color: var(--status-burn); }
  .wontdo__h {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.4rem);
    color: var(--text-bright);
    font-variation-settings: "opsz" 80, "wght" 500;
    letter-spacing: -0.022em;
    text-wrap: balance;
  }
  .wontdo__lead { color: var(--text-base); max-width: 56ch; margin: 0 auto; line-height: 1.55; }
  .wontdo__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
  }
  .wontno {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--s-4);
    padding: var(--s-5);
    border: 1px solid color-mix(in oklab, var(--status-burn) 18%, rgba(255, 255, 255, 0.08));
    border-top: 1px solid color-mix(in oklab, var(--status-burn) 30%, rgba(255, 255, 255, 0.16));
    border-radius: var(--r-4);
    background: rgba(15, 10, 10, 0.76);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    align-items: start;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.45);
  }
  .wontno--headline {
    grid-column: 1 / -1;
    border-color: color-mix(in oklab, var(--status-burn) 35%, rgba(255, 255, 255, 0.12));
    border-top: 1px solid color-mix(in oklab, var(--status-burn) 50%, rgba(255, 255, 255, 0.22));
    background: rgba(22, 10, 10, 0.82);
    box-shadow: 0 12px 40px 0 rgba(229, 72, 60, 0.08), 0 8px 32px 0 rgba(0, 0, 0, 0.45);
  }
  .wontno__x {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid color-mix(in oklab, var(--status-burn) 50%, var(--ink-line));
    border-radius: 50%;
    color: var(--status-burn);
    font-family: var(--font-mono);
    font-size: 15px;
    flex-shrink: 0;
    background: color-mix(in oklab, var(--status-burn) 10%, transparent);
  }
  .wontno__h {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--text-bright);
    font-variation-settings: "opsz" 36, "wght" 540;
    letter-spacing: -0.014em;
    line-height: 1.2;
    margin-bottom: var(--s-2);
    text-wrap: balance;
  }
  .wontno--headline .wontno__h { font-size: 1.4rem; }
  .wontno p {
    color: var(--text-base);
    font-size: 0.94rem;
    line-height: 1.55;
  }
  .wontno code {
    font-family: var(--font-mono);
    background: var(--ink-surface);
    padding: 1px 6px;
    border-radius: var(--r-2);
    border: 1px solid var(--ink-line);
    color: var(--text-bright);
  }
  .wontno p em {
    color: var(--ember-bright);
    font-style: italic;
    font-variation-settings: "opsz" 36, "ital" 1;
  }
  @media (max-width: 880px) {
    .wontdo__grid { grid-template-columns: 1fr; }
  }

  /* ────────── 7. FAQ ────────── */
  .qa {
    padding-block: var(--s-9);
    border-top: 1px solid var(--ink-line);
  }
  .qa__head {
    max-width: 64ch;
    margin: 0 auto var(--s-6);
    display: grid;
    gap: var(--s-3);
    text-align: center;
  }
  .qa__h {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.4rem);
    color: var(--text-bright);
    font-variation-settings: "opsz" 80, "wght" 500;
    letter-spacing: -0.022em;
    text-wrap: balance;
  }
  .qa__list { display: grid; gap: var(--s-4); max-width: 80ch; margin: 0 auto; }
  .qa__item {
    padding: var(--s-4);
    border: 1px solid var(--ink-line);
    border-radius: var(--r-4);
    background: var(--ink-base);
  }
  .qa__item dt {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--text-bright);
    font-variation-settings: "opsz" 36, "wght" 540;
    letter-spacing: -0.014em;
    margin-bottom: var(--s-2);
  }
  .qa__item dd { color: var(--text-base); font-size: 0.94rem; line-height: 1.55; }
  .qa__item code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    color: var(--text-bright);
    background: var(--ink-surface);
    padding: 1px 6px;
    border-radius: var(--r-2);
    border: 1px solid var(--ink-line);
  }

  /* ────────── 8. END CTA ────────── */
  .endcta--inline {
    padding-block: var(--s-9);
    text-align: center;
    background: radial-gradient(60% 80% at 50% 50%, rgba(255, 106, 26, 0.06), transparent 70%);
    border-top: 1px solid var(--ink-line);
  }
  .endcta--inline h2 {
    margin-bottom: var(--s-3);
    font-family: var(--font-display);
    color: var(--text-bright);
    font-variation-settings: "opsz" 80, "wght" 500;
  }
  .endcta__ctas { display: flex; justify-content: center; gap: var(--s-3); margin-top: var(--s-5); flex-wrap: wrap; }
  .endcta__inner {
    text-align: center;
    display: grid;
    gap: var(--s-5);
    justify-items: center;
    padding: var(--s-7) var(--s-6);
  }
</style>
