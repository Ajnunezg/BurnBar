---
import BaseLayout from "@layouts/BaseLayout.astro";
import RealDashboard from "@components/RealDashboard.astro";
import SurfaceCard from "@components/SurfaceCard.astro";
import { SURFACES } from "@data/surfaces";
import { FEATURES_BY_CATEGORY } from "@data/features";
---

<BaseLayout
  title="Product"
  description="OpenBurnBar — what it actually does. Local tracking, cost and tokens, quota windows, smart insights, daemon, CLI, Hermes assistant, surfaces."
>
  <section class="pagehead">
    <div class="container">
      <span class="eyebrow eyebrow--ember">Product</span>
      <h1 class="pagehead__h">
        Every agent, every model, every dollar — in one calm console.
      </h1>
      <p class="lead">
        OpenBurnBar reads what your agents already leave behind on disk and turns it
        into a coherent picture: today's burn, this week's pattern, this month's
        budget, every session you ran, every quota window you're about to hit.
      </p>
    </div>
  </section>

  <section>
    <div class="container container--wide">
      <RealDashboard
        src="/screens/ipad-burn.png"
        alt="OpenBurnBar iPadOS app — Burn tab with Fleet Quota 42% Pressured, per-provider rings, $18.74 today across Today / 7d / 30d / 90d / All-Time"
        caption="Real iPadOS capture · Burn tab · same SwiftUI design renders on macOS"
      />
    </div>
  </section>

  <!-- TRACKING -->
  <section class="featgroup">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Tracking</span>
        <h2>Cost, tokens, quota — local and live.</h2>
        <p class="lead">
          Numbers come from the vendor's own API or local logs. Confidence
          is labeled on every row.
        </p>
      </header>
      <ul class="featgroup__grid">
        {FEATURES_BY_CATEGORY.tracking.map((f) => (
          <li class="feat">
            <h3>{f.title}</h3>
            <p>{f.blurb}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ROUTING -->
  <section class="featgroup featgroup--routing">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Routing</span>
        <h2>Two routing modes, one local gateway.</h2>
        <p class="lead">
          The same daemon ships two postures. <strong>Provider-Family Failover</strong>
          protects your intent and extends capacity inside a single provider
          family. <strong>Intelligent Model Router</strong> scores the task and
          picks the best fit. Benchmarks are advisory signals, never absolute
          truth — user choice, auth, quota, and availability win.
        </p>
      </header>

      <ul class="routing__grid">
        <li class="routing__card routing__card--family">
          <header>
            <span class="mono routing__tag">default</span>
            <h3>Provider-Family Failover</h3>
          </header>
          <p>
            Pin an account. Add more accounts in the same family. When the
            primary throttles, the runner-up serves the next request — never
            crosses into a different family. Codex stays on OpenAI-shape,
            Claude Code stays on Anthropic-shape.
          </p>
          <ul class="routing__bullets">
            <li>Pinned account wins when healthy</li>
            <li>Runner-up pre-selected — no second policy pass</li>
            <li>5-minute cool-down on transient failures</li>
            <li>Account-level routing — no quota pool collapse</li>
          </ul>
        </li>
        <li class="routing__card routing__card--intelligent">
          <header>
            <span class="mono routing__tag routing__tag--mercury">opt-in</span>
            <h3>Intelligent Model Router</h3>
          </header>
          <p>
            Hand the router a task. It scores every candidate model on
            capability, quota health, cost, latency, context window, reliability,
            and benchmark freshness — picks the best, holds a runner-up, and
            streams a <span class="mono">decision_reason</span> with every pick.
          </p>
          <ul class="routing__bullets">
            <li>9 signals · weighted per task type</li>
            <li>Benchmarks weighted by recency · never override pins</li>
            <li>Per-surface opt-in (autopilot, scout, researcher)</li>
            <li>Explainable: every decision logged locally</li>
          </ul>
        </li>
      </ul>

      <div class="routing__cta">
        <a class="btn btn--ember" href="/router">
          Read how routing actually works <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ASSISTANT -->
  <section class="featgroup featgroup--mercury">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--mercury">Hermes</span>
        <h2>An assistant that knows your data.</h2>
        <p class="lead">
          Two runtimes share one identity. Stateless per-turn against a CLI subprocess
          for quick answers, or multi-turn against a local Hermes Gateway for
          deeper sessions — both grounded in your own OpenBurnBar SQLite.
        </p>
      </header>
      <ul class="featgroup__grid">
        {FEATURES_BY_CATEGORY.assistant.map((f) => (
          <li class="feat feat--mercury">
            <h3>{f.title}</h3>
            <p>{f.blurb}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CONTROL -->
  <section class="featgroup">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Control plane</span>
        <h2>One daemon, every surface.</h2>
        <p class="lead">
          The daemon owns provider routing, quota refresh, retrieval, projects,
          missions, and a JSONL run journal you can replay. The CLI scripts it.
          Every other surface speaks to it.
        </p>
      </header>
      <ul class="featgroup__grid">
        {FEATURES_BY_CATEGORY.control.map((f) => (
          <li class="feat">
            <h3>{f.title}</h3>
            <p>{f.blurb}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SURFACES -->
  <section class="featgroup">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">Surfaces</span>
        <h2>The screens it shows up on.</h2>
      </header>
      <ul class="surfaces__grid">
        {SURFACES.map((s, i) => <SurfaceCard surface={s} index={i} />)}
      </ul>
    </div>
  </section>

  <!-- HONESTY -->
  <section class="featgroup featgroup--quiet">
    <div class="container container--wide">
      <header class="sec-head">
        <span class="eyebrow eyebrow--ember">The honest part</span>
        <h2>What it doesn't pretend.</h2>
        <p class="lead">
          A clean console is built on what you choose to leave out as much as
          what you choose to put in.
        </p>
      </header>
      <ul class="featgroup__grid">
        {FEATURES_BY_CATEGORY.honesty.map((f) => (
          <li class="feat">
            <h3>{f.title}</h3>
            <p>{f.blurb}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="endcta endcta--inline">
    <div class="container container--narrow">
      <h2>Read it in code, not in marketing.</h2>
      <p class="lead">
        OpenBurnBar is MIT-licensed. The README, the architecture doc, the threat
        model, the provider matrix, the changelog — all in the open.
      </p>
      <div class="endcta__ctas">
        <a class="btn btn--ember" href="/download">Download for macOS <span class="btn-arrow" aria-hidden="true">→</span></a>
        <a class="btn btn--ghost" href="/providers">See provider matrix</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pagehead {
    padding-block: var(--s-9) var(--s-6);
  }
  .pagehead__h {
    margin-top: var(--s-3);
    max-width: 22ch;
  }
  .pagehead .lead {
    margin-top: var(--s-4);
    max-width: 60ch;
  }
  .featgroup {
    padding-block: var(--s-9);
    border-top: 1px solid var(--ink-line);
  }
  .featgroup--quiet {
    background: var(--ink-base);
  }
  .featgroup--mercury {
    background:
      radial-gradient(60% 60% at 100% 50%, rgba(214, 211, 223, 0.04), transparent 70%);
  }
  .sec-head {
    display: grid;
    gap: var(--s-3);
    margin-bottom: var(--s-6);
    max-width: 64ch;
  }
  .featgroup__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-4);
  }
  .feat {
    padding: var(--s-5);
    border: 1px solid var(--ink-line);
    border-radius: var(--r-4);
    background: var(--ink-base);
    display: grid;
    gap: var(--s-2);
  }
  .feat h3 {
    font-size: 1.1rem;
    font-family: var(--font-display);
    color: var(--text-bright);
    font-variation-settings: "opsz" 36, "wght" 540;
    letter-spacing: -0.014em;
  }
  .feat p { color: var(--text-base); font-size: 0.94rem; }
  .feat--mercury {
    border-color: color-mix(in oklab, var(--mercury-bright) 22%, var(--ink-line));
  }
  .surfaces__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-4);
  }
  @media (max-width: 1080px) {
    .featgroup__grid { grid-template-columns: repeat(2, 1fr); }
    .surfaces__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .featgroup__grid { grid-template-columns: 1fr; }
    .surfaces__grid { grid-template-columns: 1fr; }
  }
  .endcta--inline {
    padding-block: var(--s-9);
    text-align: center;
    background:
      radial-gradient(60% 80% at 50% 50%, rgba(255, 106, 26, 0.05), transparent 70%);
  }
  .endcta--inline h2 { margin-bottom: var(--s-3); }
  .endcta--inline .lead { margin: 0 auto; }
  .endcta__ctas { display: flex; justify-content: center; gap: var(--s-3); margin-top: var(--s-5); flex-wrap: wrap; }

  /* ─── routing ─── */
  .featgroup--routing {
    background:
      radial-gradient(70% 60% at 50% 0%, rgba(255, 106, 26, 0.05), transparent 60%),
      radial-gradient(50% 60% at 95% 100%, rgba(214, 211, 223, 0.04), transparent 70%);
  }
  .routing__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
    list-style: none;
  }
  .routing__card {
    display: grid;
    gap: var(--s-3);
    padding: var(--s-5);
    border: 1px solid var(--ink-line);
    border-radius: var(--r-4);
    background:
      linear-gradient(180deg, var(--ink-surface) 0%, var(--ink-base) 100%);
  }
  .routing__card--family {
    border-color: color-mix(in oklab, var(--ember-core) 32%, var(--ink-line));
    background:
      linear-gradient(180deg, rgba(255, 106, 26, 0.05) 0%, var(--ink-base) 100%);
  }
  .routing__card--intelligent {
    border-color: color-mix(in oklab, var(--mercury-bright) 30%, var(--ink-line));
    background:
      linear-gradient(180deg, rgba(214, 211, 223, 0.05) 0%, var(--ink-base) 100%);
  }
  .routing__card header {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--s-3);
  }
  .routing__card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--text-bright);
    font-variation-settings: "opsz" 36, "wght" 540;
    letter-spacing: -0.018em;
    line-height: 1.15;
  }
  .routing__tag {
    color: var(--ember-bright);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 1px 6px;
    border-radius: var(--r-pill);
    border: 1px solid color-mix(in oklab, var(--ember-core) 40%, var(--ink-line));
    background: color-mix(in oklab, var(--ember-core) 8%, transparent);
  }
  .routing__tag--mercury {
    color: var(--mercury-bright);
    border-color: color-mix(in oklab, var(--mercury-bright) 35%, var(--ink-line));
    background: color-mix(in oklab, var(--mercury-bright) 8%, transparent);
  }
  .routing__card p {
    color: var(--text-base);
    font-size: 0.94rem;
    line-height: 1.55;
  }
  .routing__bullets {
    list-style: none;
    display: grid;
    gap: var(--s-2);
    margin-top: var(--s-2);
    padding-top: var(--s-3);
    border-top: 1px dashed var(--ink-line-soft);
  }
  .routing__bullets li {
    color: var(--text-base);
    font-size: 0.9rem;
    padding-left: var(--s-4);
    position: relative;
  }
  .routing__bullets li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--ember-bright);
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  .routing__card--intelligent .routing__bullets li::before { color: var(--mercury-bright); }
  .routing__cta {
    margin-top: var(--s-5);
    display: flex;
    justify-content: flex-start;
  }
  @media (max-width: 960px) {
    .routing__grid { grid-template-columns: 1fr; }
  }
</style>
