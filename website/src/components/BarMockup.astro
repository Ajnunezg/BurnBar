---
// Real macOS menu-bar popover screenshot — captured 2026-05-12 from the
// installed OpenBurnBar.app (showing 11,377 sessions of live data).
---

<figure class="bar-mockup" aria-label="The real OpenBurnBar menu-bar popover showing live quota windows for Anthropic and Codex, plus an active mission with $2,662.51 burned across 15.12 billion tokens">
  <div class="bar-mockup__chrome" aria-hidden="true">
    <div class="bar-mockup__menubar">
      <span class="dot"></span>
      <span class="dot"></span>
      <span class="dot"></span>
      <span class="bar-mockup__menubar-spacer"></span>
      <img
        src="/brand/logo-64.png"
        srcset="/brand/logo-64.png 1x, /brand/logo-256.png 2x"
        alt=""
        width="14"
        height="14"
        class="bar-mockup__menubar-logo"
      />
      <span class="bar-mockup__menubar-label">OpenBurnBar</span>
      <span class="bar-mockup__menubar-cap mono">Today · 0 tok</span>
    </div>
    <div class="bar-mockup__menubar-arrow" aria-hidden="true"></div>
  </div>

  <img
    src="/screens/macos-popover.png"
    alt=""
    width="540"
    height="600"
    class="bar-mockup__shot"
    decoding="async"
    fetchpriority="high"
  />

  <figcaption class="bar-mockup__cap mono">
    Real menu-bar popover · 11,377 sessions, live quota windows
  </figcaption>
</figure>

<style>
  .bar-mockup {
    --w: 340px;
    display: grid;
    gap: 12px;
    width: 100%;
    max-width: var(--w);
    margin: 0;
    container-type: inline-size;
  }
  .bar-mockup__chrome {
    position: relative;
  }
  .bar-mockup__menubar {
    background: linear-gradient(180deg, #1a1822 0%, #14111c 100%);
    border: 1px solid var(--ink-line);
    border-radius: 10px;
    height: 30px;
    padding: 0 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: var(--shadow-card);
  }
  .bar-mockup__menubar .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2a2434;
  }
  .bar-mockup__menubar-spacer { flex: 1; }
  .bar-mockup__menubar-logo { border-radius: 22%; }
  .bar-mockup__menubar-label {
    color: var(--text-bright);
    font-size: 12.5px;
    font-variation-settings: "wght" 540;
  }
  .bar-mockup__menubar-cap {
    font-size: 11px;
    color: var(--text-mute);
    letter-spacing: 0.04em;
  }
  .bar-mockup__menubar-arrow {
    position: absolute;
    bottom: -7px;
    right: 28px;
    width: 12px;
    height: 12px;
    background: linear-gradient(180deg, #1a1822 0%, #14111c 100%);
    border: 1px solid var(--ink-line);
    border-top: 0;
    border-left: 0;
    transform: rotate(45deg);
  }
  .bar-mockup__shot {
    width: 100%;
    height: auto;
    border-radius: 14px;
    box-shadow:
      0 28px 80px -36px rgba(0, 0, 0, 0.95),
      0 0 0 1px rgba(255, 106, 26, 0.10),
      0 0 60px -8px rgba(255, 106, 26, 0.20);
    background: var(--ink-base);
  }
  .bar-mockup__cap {
    font-size: var(--t-caption);
    color: var(--text-dim);
    text-align: center;
    letter-spacing: 0.04em;
  }
</style>
