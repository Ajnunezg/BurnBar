    color: var(--text-base);
    cursor: pointer;
    font-size: 0.75rem;
    transition: all 0.2s var(--ease);
  }
  .sim-action:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-bright);
    border-color: var(--ink-line-bright);
  }
  .sim-action svg {
    opacity: 0.8;
  }
  .sim-action:hover svg {
    opacity: 1;
  }

  .sim-speed {
    display: flex;
    align-items: center;
    gap: var(--s-2);
  }
  .sim-speed__label {
    font-size: 0.75rem;
    color: var(--text-dim);
  }
  .speed-range {
    -webkit-appearance: none;
    appearance: none;
    width: 70px;
    height: 3px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }
  .speed-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ff8a3d;
    box-shadow: 0 0 6px #ff8a3d;
    transition: transform 0.1s var(--ease);
  }
  .speed-range::-webkit-slider-thumb:hover {
    transform: scale(1.3);
  }
  .sim-speed__val {
    font-size: 0.75rem;
    width: 32px;
    color: #ff8a3d;
  }

  /* Panel Redesign: SVG Canvas & Legend Grid */
  .lifecycle__panel {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--s-4);
