---
/**
 * Hardware shell for a platform mockup.
 *
 * Renders the device chassis in pure CSS and slots the screen-content child
 * inside a clipped display area. The geometry is derived from front-on
 * reference photos of each device so the silhouette is recognisable rather
 * than aspirational.
 *
 * Kinds:
 *   - "nest-hub"     — 7" display rectangle sitting on a wider chalk fabric
 *                      pedestal. The pedestal lives BELOW the screen and
 *                      NEVER overlaps the slotted content.
 *   - "ulanzi-tc001" — cream desk box with three top buttons, a recessed
 *                      32×8 LED panel, two feet, and a trailing USB-C cable.
 */

interface Props {
  kind: "nest-hub" | "ulanzi-tc001";
  label?: string;
}
const { kind, label } = Astro.props;
---

{
  kind === "nest-hub" && (
    <div
      class="deviceframe deviceframe--nest"
      role="img"
      aria-label={label ?? "Google Nest Hub device frame"}
    >
      <div class="deviceframe__nest-shelf">
        <div class="deviceframe__nest-bezel">
          <div class="deviceframe__nest-glass">
            <slot />
            <div class="deviceframe__nest-reflection" aria-hidden="true" />
          </div>
          <span class="deviceframe__nest-camera" aria-hidden="true" />
        </div>
      </div>

      <div class="deviceframe__nest-pedestal" aria-hidden="true">
        <div class="deviceframe__nest-fabric" />
        <div class="deviceframe__nest-weave" />
        <div class="deviceframe__nest-toplight" />
      </div>

      <div class="deviceframe__nest-floor" aria-hidden="true" />
    </div>
  )
}

{
  kind === "ulanzi-tc001" && (
    <div
      class="deviceframe deviceframe--ulanzi"
      role="img"
      aria-label={label ?? "Ulanzi TC001 pixel clock"}
    >
      <div class="deviceframe__ulanzi-cable" aria-hidden="true">
        <span class="deviceframe__ulanzi-cable-plug" />
      </div>

      <div class="deviceframe__ulanzi-body">
        <div class="deviceframe__ulanzi-toprail" aria-hidden="true">
          <span class="deviceframe__ulanzi-button" />
          <span class="deviceframe__ulanzi-button" />
          <span class="deviceframe__ulanzi-button" />
        </div>
        <div class="deviceframe__ulanzi-top-highlight" aria-hidden="true" />

        <div class="deviceframe__ulanzi-panel">
          <slot />
        </div>

        <div class="deviceframe__ulanzi-feet" aria-hidden="true">
          <>
            <span />
            <span />
          </>
        </div>
      </div>

      <div class="deviceframe__ulanzi-floor" aria-hidden="true" />
    </div>
  )
}

<style>
  .deviceframe {
    position: relative;
    width: 100%;
    container-type: inline-size;
  }

  /* ═════════════════════════ NEST HUB ═════════════════════════
     Real Nest Hub (2nd gen) viewed head-on:
       1. The display unit is a slightly-rounded rectangle in matte black
          with chunky bezels — equal on top + sides, thicker on the bottom
          to make room for the ambient-light sensor / mic.
       2. The chalk-fabric pedestal sits BELOW the display, the same width,
          extending the silhouette downward by ~25% of the display height.
          It is a soft pillow shape, not a tall oval.
       3. From the front the device reads as one coherent shape — screen on
          top, fabric pillow underneath, no visible hinge or mount.

     Layout: a vertical flex stack. Display is the first child; pedestal is
     the second child; the floor shadow is absolute under both.
  ─────────────────────────────────────────────────────────────── */
  .deviceframe--nest {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 0.5%;
    position: relative;
  }

  /* SHELF — the display unit. Filter drop-shadow falls on the pedestal
     below for a real-world contact shadow. */
  .deviceframe__nest-shelf {
    width: 100%;
    z-index: 2;
    filter: drop-shadow(0 16px 28px rgba(0, 0, 0, 0.5));
  }
  /* BEZEL — chunky matte black with extra room on the bottom for the
     chin (where the camera + sensors live on the real device). */
  .deviceframe__nest-bezel {
    width: 100%;
    background: linear-gradient(180deg, #1d181f 0%, #0e0c11 100%);
    border-radius: 10px;
    padding: 5.2% 4.5% 9.5%;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      inset 0 -1px 8px rgba(0, 0, 0, 0.55);
    position: relative;
  }
  .deviceframe__nest-glass {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 3px;
    overflow: hidden;
    background: #07060a;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.06),
      inset 0 0 14px rgba(0, 0, 0, 0.55);
  }
  .deviceframe__nest-reflection {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      115deg,
      rgba(255, 255, 255, 0.08) 0%,
      transparent 32%,
      transparent 68%,
      rgba(255, 255, 255, 0.05) 95%
    );
    mix-blend-mode: screen;
    opacity: 0.55;
  }
  /* CAMERA dot embedded in the chin (bottom bezel area). The real Nest Hub
     2nd gen does not have a front-facing camera — only an ambient-light
     sensor — so the dot is intentionally subtle. */
  .deviceframe__nest-camera {
    position: absolute;
    bottom: 3.3%;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(4px, 0.85cqi, 7px);
    height: clamp(4px, 0.85cqi, 7px);
    border-radius: 50%;
    background: radial-gradient(closest-side, #2a2030 35%, #0a070d 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 0 4px rgba(0, 0, 0, 0.6);
    pointer-events: none;
  }

  /* PEDESTAL — chalk-fabric pillow. Narrower than the display rectangle so
     the device reads as "screen on a smaller speaker base" — matches the
     real Nest Hub silhouette from a front-view photo. */
  .deviceframe__nest-pedestal {
    position: relative;
    width: 76%;
    aspect-ratio: 7.2 / 1;
    margin-top: -0.3%;
    border-radius: 22% 22% 30% 30% / 60% 60% 100% 100%;
    background: radial-gradient(140% 110% at 50% -20%, #fbf3e2 0%, #e8dcc1 45%, #c1ad88 100%);
    box-shadow:
      inset 0 2px 0 rgba(255, 255, 255, 0.6),
      inset 0 -8px 12px rgba(0, 0, 0, 0.16),
      0 14px 24px -6px rgba(0, 0, 0, 0.55);
    overflow: hidden;
    z-index: 1;
  }
  /* Fabric grain — dual-offset dot field at marketing-zoom visibility. */
  .deviceframe__nest-fabric {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background-image:
      radial-gradient(rgba(0, 0, 0, 0.2) 0.8px, transparent 1.2px),
      radial-gradient(rgba(255, 255, 255, 0.18) 0.8px, transparent 1.2px);
    background-size:
      4px 4px,
      4px 4px;
    background-position:
      0 0,
      2px 2px;
    mix-blend-mode: multiply;
    opacity: 0.55;
  }
  /* Diagonal weave overlay for direction. */
  .deviceframe__nest-weave {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background-image:
      repeating-linear-gradient(38deg, rgba(0, 0, 0, 0.04) 0 1px, transparent 1px 3px),
      repeating-linear-gradient(-38deg, rgba(0, 0, 0, 0.04) 0 1px, transparent 1px 3px);
    mix-blend-mode: multiply;
    opacity: 0.7;
    pointer-events: none;
  }
  /* Soft highlight along the crown of the pillow. */
  .deviceframe__nest-toplight {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(70% 45% at 50% 0%, rgba(255, 255, 255, 0.4), transparent 75%);
    pointer-events: none;
  }
  /* FLOOR — soft contact shadow. */
  .deviceframe__nest-floor {
    width: 70%;
    height: clamp(10px, 2.4cqi, 22px);
    margin-top: -2.5%;
    border-radius: 50%;
    background: radial-gradient(60% 100% at 50% 50%, rgba(0, 0, 0, 0.5), transparent 75%);
    filter: blur(10px);
    z-index: 0;
  }

  /* ═════════════════════════ ULANZI TC001 ═════════════════════════
     Real Ulanzi TC001 viewed head-on:
       - Cream/off-white rectangular body, slightly rounded corners,
         aspect ratio roughly 2.6:1.
       - LED panel takes the majority of the front face.
       - 3 small slot-shaped buttons on the top edge.
       - 2 dark feet at the bottom.
       - USB-C cable trailing out the right side.
  ─────────────────────────────────────────────────────────────── */
  .deviceframe--ulanzi {
    aspect-ratio: 2.6 / 1;
    padding: 0 6% 4%;
    position: relative;
  }
  .deviceframe__ulanzi-cable {
    position: absolute;
    right: 1%;
    top: 36%;
    width: 14%;
    height: 6px;
    border-radius: 3px;
    background: linear-gradient(90deg, #1a1422 0%, #2a2030 60%, transparent 100%);
    transform: rotate(-4deg);
    transform-origin: left center;
    z-index: 0;
  }
  .deviceframe__ulanzi-cable-plug {
    position: absolute;
    left: -8px;
    top: -3px;
    width: 10px;
    height: 12px;
    border-radius: 2px;
    background: linear-gradient(180deg, #2a2030 0%, #1a1422 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.05),
      0 1px 3px rgba(0, 0, 0, 0.4);
  }
  .deviceframe__ulanzi-body {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 10px;
    background: linear-gradient(180deg, #f7f0e2 0%, #ede2cd 40%, #d5c6a8 100%);
    border: 1px solid rgba(0, 0, 0, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      inset 0 -2px 4px rgba(0, 0, 0, 0.18),
      0 14px 24px rgba(0, 0, 0, 0.5),
      0 2px 0 rgba(255, 255, 255, 0.45);
    padding: 9% 6% 8%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }
  /* Top-rail buttons — three small slot-shaped buttons sitting on the
     top edge of the case, like the real device. Sits above the bezel. */
  .deviceframe__ulanzi-toprail {
    position: absolute;
    top: -3px;
    right: 14%;
    display: flex;
    gap: clamp(4px, 1.2cqi, 10px);
    z-index: 2;
  }
  .deviceframe__ulanzi-button {
    width: clamp(10px, 3cqi, 26px);
    height: clamp(3px, 0.8cqi, 6px);
    border-radius: 2px 2px 0 0;
    background: linear-gradient(180deg, #efe4cc 0%, #c4b288 100%);
    border: 1px solid rgba(0, 0, 0, 0.22);
    border-bottom: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      0 -2px 2px rgba(0, 0, 0, 0.18);
  }
  /* Top-edge cream highlight. */
  .deviceframe__ulanzi-top-highlight {
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 16%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.55), transparent 100%);
    border-radius: 10px 10px 0 0;
    opacity: 0.55;
    pointer-events: none;
  }
  .deviceframe__ulanzi-panel {
    width: 100%;
    border-radius: 4px;
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.28),
      inset 0 1px 2px rgba(0, 0, 0, 0.5);
  }
  .deviceframe__ulanzi-feet {
    position: absolute;
    left: 14%;
    right: 14%;
    bottom: -5px;
    height: clamp(4px, 1.2cqi, 10px);
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }
  .deviceframe__ulanzi-feet span {
    width: clamp(14px, 4.5cqi, 36px);
    height: 100%;
    background: linear-gradient(180deg, #2a2030 0%, #18141a 100%);
    border-radius: 0 0 4px 4px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 2px 4px rgba(0, 0, 0, 0.5);
  }
  .deviceframe__ulanzi-floor {
    position: absolute;
    left: 8%;
    right: 8%;
    bottom: -10px;
    height: 8px;
    border-radius: 50%;
    background: radial-gradient(60% 100% at 50% 50%, rgba(0, 0, 0, 0.45), transparent 75%);
    filter: blur(8px);
    z-index: 0;
  }
</style>
