---
/**
 * Four real-world Fire Hydrant routing scenarios. Every claim maps to a
 * routing-policy behaviour in
 * OpenBurnBarCore/.../ProviderAccountTypes.swift:403-599 or to a state
 * surfaced by ProviderRoutingStateBuilder.swift.
 */

interface Props {
  /** When true, renders 2-up on wide viewports instead of 4-up (used inside narrower containers). */
  twoUp?: boolean;
}

const { twoUp = false } = Astro.props;

type Case = {
  id: string;
  flow: Array<{ logo: string; alt: string }>;
  arrow: string;
  headline: string;
  body: string;
  badge: string;
  badgeClass: string;
  evidence: string;
};

const CASES: Case[] = [
  {
    id: "claude-pro-failover",
    flow: [
      { logo: "/brand/providers/claude-code.png", alt: "Claude Pro #1" },
      { logo: "/brand/providers/anthropic.png", alt: "Claude Pro #2 / Console" }
    ],
    arrow: "→",
    headline: "Claude Pro caps out. The second Pro plan answers the next message.",
    body:
      "Claude Code hits the 5-hour limit on your primary Pro plan. The hydrant marks that slot exhausted, parks it for the rolling window, and the next /v1/messages call lands on your second Pro plan — or your Anthropic Console key — all in the Anthropic pool.",
    badge: "anthropic-family failover",
    badgeClass: "tag tag--mercury tag--plain mono",
    evidence: "OpenBurnBarHTTPGatewayServer.swift · /v1/messages handler · testGatewayFailsOverAnthropicAccountOnQuotaExhausted"
  },
  {
    id: "codex-byok-fallback",
    flow: [
      { logo: "/brand/providers/codex.png", alt: "Codex CLI" },
      { logo: "/brand/providers/openai.png", alt: "OpenAI API key" },
      { logo: "/brand/providers/zai.png", alt: "Z.ai" }
    ],
    arrow: "→",
    headline: "Codex CLI in API-key mode. ChatGPT key dry? OpenAI then Z.ai picks up.",
    body:
      "Set OPENAI_BASE_URL to the hydrant. Pin your ChatGPT API key as preferred for cost. When it runs out, the router shifts to the OpenAI pay-as-you-go account, and if that's also pressured, to your Z.ai plan. Same OpenAI shape end to end.",
    badge: "openai-family failover",
    badgeClass: "tag tag--exact tag--plain mono",
    evidence: "ROUTED_CLIENT_GATEWAY.md · preferred-provider + LRU within OpenAI-family pool"
  },
  {
    id: "openai-roundrobin",
    flow: [
      { logo: "/brand/providers/zai.png", alt: "Z.ai" },
      { logo: "/brand/providers/minimax.png", alt: "MiniMax" },
      { logo: "/brand/providers/kimi.png", alt: "Kimi" }
    ],
    arrow: "⇄",
    headline: "Three OpenAI-compatible vendors. LRU spreads the load.",
    body:
      "Z.ai, MiniMax, and Kimi all speak OpenAI-shape JSON. When all three are healthy on a fungible model, the router round-robins by least-recently-used — fair share across your accounts instead of hammering one until it goes red.",
    badge: "round-robin",
    badgeClass: "tag tag--ember tag--plain mono",
    evidence: "ProviderRoutingPolicy.decide · ranks by quota-health, then sortKey, then LRU"
  },
  {
    id: "format-isolation",
    flow: [
      { logo: "/brand/providers/claude-code.png", alt: "Claude Code" },
      { logo: "/brand/providers/anthropic.png", alt: "Anthropic" }
    ],
    arrow: "≠",
    headline: "No cross-format hacks. Anthropic never gets an OpenAI prompt.",
    body:
      "A Claude Code request hitting /v1/messages can only be served by accounts in the Anthropic pool. If you have no Anthropic accounts configured, the hydrant returns a structured 503 telling you exactly which pool you're missing — not a corrupted response, not a tool-call schema mismatch.",
    badge: "pool isolation",
    badgeClass: "tag tag--mercury tag--plain mono",
    evidence: "ProviderAccountTypes.swift · formatFamily filter · testGatewayMessagesReturns503WhenOnlyOpenAICompatProvidersConfigured"
  }
];
---

<div class={`usecases ${twoUp ? "usecases--two" : ""}`}>
  {CASES.map((c, idx) => (
    <article class="ucard" style={`--idx:${idx}`}>
      <header class="ucard__flow" aria-hidden="true">
        {c.flow.map((node, i) => (
          <>
            <img
              class="ucard__logo"
              src={node.logo}
              alt={node.alt}
              width="32"
              height="32"
              loading="lazy"
              decoding="async"
            />
            {i < c.flow.length - 1 && (
              <span class="ucard__arrow mono">{c.arrow}</span>
            )}
          </>
        ))}
      </header>
      <span class={c.badgeClass}>{c.badge}</span>
      <h3 class="ucard__h">{c.headline}</h3>
      <p class="ucard__body">{c.body}</p>
      <p class="ucard__evidence mono" aria-label="Evidence file and behaviour">
        <span class="ucard__bullet">·</span>
        {c.evidence}
      </p>
    </article>
  ))}
</div>

<style>
  .usecases {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-4);
  }
  .usecases--two {
    grid-template-columns: repeat(2, 1fr);
  }

  .ucard {
    display: grid;
    gap: var(--s-3);
    align-content: start;
    padding: var(--s-5);
    border: 1px solid var(--ink-line);
    border-radius: var(--r-4);
    background: linear-gradient(180deg, var(--ink-surface) 0%, var(--ink-base) 100%);
    position: relative;
    transition: border-color var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out);
    animation: ucard-rise 0.7s var(--ease-out) both;
    animation-delay: calc(var(--idx, 0) * 110ms);
  }
  @keyframes ucard-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .ucard::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(255, 106, 26, 0.05), transparent 50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-out);
  }
  .ucard:hover {
    border-color: color-mix(in oklab, var(--ember-core) 35%, var(--ink-line));
    transform: translateY(-3px);
  }
  .ucard:hover::after {
    opacity: 1;
  }

  .ucard__flow {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    flex-wrap: wrap;
  }
  .ucard__logo {
    width: 32px;
    height: 32px;
    border-radius: 7px;
    border: 1px solid var(--ink-line);
    background: var(--ink-base);
    object-fit: cover;
    display: block;
  }
  .ucard__arrow {
    color: var(--ember-bright);
    font-size: 1.05rem;
    line-height: 1;
  }

  .ucard__h {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--text-bright);
    font-variation-settings: "opsz" 36, "wght" 540;
    letter-spacing: -0.018em;
    line-height: 1.18;
    text-wrap: balance;
  }
  .ucard__body {
    color: var(--text-base);
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .ucard__evidence {
    color: var(--text-dim);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    line-height: 1.45;
    padding-top: var(--s-3);
    border-top: 1px dashed var(--ink-line-soft);
    margin-top: auto;
  }
  .ucard__bullet {
    color: var(--ember-bright);
    margin-right: 0.4em;
  }

  @media (max-width: 1080px) {
    .usecases { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .usecases { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ucard { animation: none !important; }
  }
</style>
