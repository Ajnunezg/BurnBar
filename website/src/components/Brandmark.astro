---
interface Props {
  size?: number;
  withWordmark?: boolean;
}

const { size = 28, withWordmark = true } = Astro.props;
---

<a href="/" class="brand" aria-label="OpenBurnBar — home">
  <img
    src="/brand/logo-256.png"
    srcset="/brand/logo-256.png 1x, /brand/logo-512.png 2x"
    alt=""
    width={size}
    height={size}
    class="brand__logo"
    decoding="async"
    fetchpriority="high"
  />
  {
    withWordmark && (
      <span class="wordmark">
        <>
          <span class="wordmark__pre">Open</span>
          <span class="wordmark__post">BurnBar</span>
        </>
      </span>
    )
  }
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    letter-spacing: -0.018em;
    color: var(--text-bright);
    font-size: 1.08rem;
    font-variation-settings:
      "opsz" 24,
      "wght" 540;
  }
  .brand:hover {
    color: var(--text-bright);
  }
  .brand__logo {
    border-radius: 22%;
    display: block;
    transition:
      filter var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }
  .brand:hover .brand__logo {
    filter: drop-shadow(0 0 12px rgba(255, 106, 26, 0.55));
    transform: rotate(-2deg);
  }
  .wordmark {
    display: inline-flex;
    line-height: 1;
  }
  .wordmark__pre {
    color: var(--text-mute);
    font-variation-settings:
      "opsz" 24,
      "wght" 420;
  }
  .wordmark__post {
    color: var(--text-bright);
    font-variation-settings:
      "opsz" 24,
      "wght" 540;
  }
</style>
