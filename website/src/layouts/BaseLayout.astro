---
import "@styles/globals.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE } from "@data/site";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  pathname?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = "/og/default.png",
  pathname,
  noindex = false
} = Astro.props;

const canonical = new URL(pathname ?? Astro.url.pathname, SITE.url).toString();
const fullTitle =
  title === SITE.name ? `${SITE.name} — ${SITE.tagline}` : `${title} — ${SITE.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#07060a" />
    <meta name="color-scheme" content="dark" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, SITE.url).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, SITE.url).toString()} />

    <!-- Icons (the real OpenBurnBar app icon at multiple sizes) -->
    <link rel="icon" type="image/png" sizes="32x32" href="/brand/logo-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/brand/favicon-64.png" />
    <link rel="icon" type="image/png" sizes="256x256" href="/brand/logo-256.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Preconnect: none. We self-host fonts. -->

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: SITE.name,
      applicationCategory: "DeveloperApplication",
      operatingSystem: "macOS 14+, iOS 17+",
      description,
      url: SITE.url,
      offers: [
        {
          "@type": "Offer",
          price: "0",
          priceCurrency: "USD",
          name: "Local-first (free)"
        },
        {
          "@type": "Offer",
          price: SITE.iapPriceUSD,
          priceCurrency: "USD",
          name: "Hosted Quota Sync (monthly)"
        }
      ]
    })} />
  </head>
  <body>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
