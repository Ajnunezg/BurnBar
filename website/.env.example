# Copy to .env and fill in. Loaded automatically by `npm run research`
# and `npm run build` via `node --env-file-if-exists=.env`. Both scripts
# tolerate a missing .env (build skips research, research errors out).
#
# All keys are optional — the rundown gracefully degrades to whichever
# sources are reachable. Every absent / errored source is marked in the
# daily rundown so the page never silently fabricates rankings.

# Artificial Analysis · https://artificialanalysis.ai
# Surfaces OpenAI, Anthropic, Google, etc. with intelligence + coding
# indices, blended pricing, TPS, TTFT. Without this, the rundown can
# only use public Hugging Face leaderboards (Terminal-Bench).
ARTIFICIAL_ANALYSIS_API_KEY=

# Design Arena · https://www.designarena.ai
# Pairwise Elo + win-rate for design / UI tasks. If both the API key
# and the fixture below are missing, design-task rankings are empty.
DESIGN_ARENA_API_KEY=

# Optional cached fixture for Design Arena (JSON-stringified array of
# rows). Used when the live API is unreachable; sources stay visible
# but marked `stale`.
# DESIGN_ARENA_FIXTURE_JSON=

# Operator-curated gap-fill snapshot (JSON-stringified). Marked
# `manual` in the source banner — useful when a model has no
# benchmark coverage in any live source yet.
# MODEL_LANDSCAPE_MANUAL_FIXTURES_JSON=
