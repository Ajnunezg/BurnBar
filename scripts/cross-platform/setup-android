#!/bin/bash
# Verify Android development environment.
# Usage:  scripts/setup-android
set -euo pipefail

cd "$(dirname "$0")/../.."
ANDROID_DIR="android"

echo "🔎 Checking Android dev environment…"

# Java 21
resolve_java_home() {
    if [ -n "${JAVA_HOME:-}" ] && [ -x "${JAVA_HOME}/bin/java" ]; then
        echo "${JAVA_HOME}"
        return
    fi
    for candidate in \
        "${HOME}/.homebrew/opt/openjdk@21" \
        "/opt/homebrew/opt/openjdk@21" \
        "/usr/local/opt/openjdk@21"; do
        if [ -x "${candidate}/bin/java" ]; then
            echo "${candidate}"
            return
        fi
    done
    if command -v java >/dev/null 2>&1; then
        java_bin="$(command -v java)"
        java_bin="$(readlink -f "${java_bin}" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "${java_bin}")"
        echo "$(dirname "$(dirname "${java_bin}")")"
        return
    fi
    echo ""
}

JAVA_HOME="$(resolve_java_home)"
if [ -n "${JAVA_HOME}" ]; then
    export JAVA_HOME
fi

JAVA_VER=$("${JAVA_HOME:-}/bin/java" -version 2>&1 | grep "version" | sed 's/.*version "\([0-9]*\)\.[0-9.]*".*/\1/' || echo "0")
if [ "$JAVA_VER" -lt 17 ]; then
    echo "❌ Java 21+ required (found Java $JAVA_VER). Install: brew install openjdk@21"
    if [ -d "${HOME}/.homebrew/opt/openjdk@21" ]; then
        echo "   → Found Homebrew openjdk@21. Run: export JAVA_HOME=$HOME/.homebrew/opt/openjdk@21"
    elif [ -d "/opt/homebrew/opt/openjdk@21" ]; then
        echo "   → Found Homebrew openjdk@21. Run: export JAVA_HOME=/opt/homebrew/opt/openjdk@21"
    fi
    exit 1
fi
echo "   ✓ Java $JAVA_VER at $JAVA_HOME"

# Android SDK
if [ -z "${ANDROID_HOME:-}" ] && [ -z "${ANDROID_SDK_ROOT:-}" ]; then
    echo "❌ ANDROID_HOME not set."
    echo "   Create ~/.zshrc entry: export ANDROID_HOME=\$HOME/Library/Android"
    exit 1
fi
echo "   ✓ ANDROID_HOME=${ANDROID_HOME:-$ANDROID_SDK_ROOT}"

# Gradle wrapper
if [ ! -f "$ANDROID_DIR/gradlew" ]; then
    echo "❌ android/gradlew not found."
    exit 1
fi
echo "   ✓ gradlew exists"

# google-services.json
if [ ! -f "$ANDROID_DIR/app/google-services.json" ]; then
    echo "   ⚠ google-services.json missing."
    if [ -f "$ANDROID_DIR/app/google-services.json.template" ]; then
        echo "   → A template exists. Download the real config from Firebase Console and copy it:"
        echo "     cp ~/Downloads/google-services.json $ANDROID_DIR/app/google-services.json"
    else
        echo "   → Register the app in Firebase Console (Project: burnbar, Package: com.openburnbar)"
        echo "     then download google-services.json to $ANDROID_DIR/app/"
    fi
else
    echo "   ✓ google-services.json exists"
fi

# Emulator check
if command -v emulator &>/dev/null; then
    EMUS=$($ANDROID_HOME/emulator/emulator -list-avds 2>/dev/null || echo "")
    if [ -z "$EMUS" ]; then
        echo "   ⚠ No Android emulator AVDs found. Create one via Android Studio → Device Manager."
    else
        echo "   ✓ Emulator available: $(echo "$EMUS" | head -1)"
    fi
else
    echo "   ⚠ emulator CLI not found. Install via Android Studio → SDK Manager → Emulator."
fi

echo "✅ Android environment ready."
