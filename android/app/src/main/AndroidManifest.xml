<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Hermes Square Phase D voice command surface + Mercury Media (1:1
         video + audio call) microphone capture. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <!-- Mercury Media Phase 5: camera capture for 1:1 video call. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.front" android:required="false" />

    <!-- Mercury Media Phase 5: foreground service while a call session
         is active. Granular sub-types per Android 14 + 15 enforcement. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />

    <!-- Mercury Media Phase 5: incoming-call sheet from FCM data push. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Android 14: Picture-in-Picture is opt-in via this feature flag. -->
    <uses-feature android:name="android.software.picture_in_picture" android:required="false" />

    <queries>
        <!-- Hermes Square Phase D — RecognizerIntent.ACTION_RECOGNIZE_SPEECH
             requires the host app to declare it can resolve the speech-
             recognition activity. Without this, SpeechRecognizer reports
             "no recognition services found" on Android 11+. -->
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:name=".BurnBarApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="BurnBar"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.BurnBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.BurnBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="burnbar" />
            </intent-filter>
        </activity>

        <!-- BurnBar widgets — five Glance surfaces (3 home + 2 lock-screen) -->
        <!-- Small (2×2). Class name is BurnBarWidgetReceiver so already-pinned
             widgets from the legacy stub keep binding without a re-pin. -->
        <receiver
            android:name=".ui.widget.BurnBarWidgetReceiver"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/burnbar_widget_info" />
        </receiver>

        <!-- Medium (4×2). -->
        <receiver
            android:name=".ui.widget.BurnBarMediumWidgetReceiver"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/burnbar_widget_medium_info" />
        </receiver>

        <!-- Large (4×4). -->
        <receiver
            android:name=".ui.widget.BurnBarLargeWidgetReceiver"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/burnbar_widget_large_info" />
        </receiver>

        <!-- Lock-screen circular (1×1, keyguard|home_screen). -->
        <receiver
            android:name=".ui.widget.BurnBarLockCircularWidgetReceiver"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/burnbar_widget_lock_circular_info" />
        </receiver>

        <!-- Lock-screen rectangular (3×1, keyguard|home_screen). -->
        <receiver
            android:name=".ui.widget.BurnBarLockRectangularWidgetReceiver"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/burnbar_widget_lock_rectangular_info" />
        </receiver>

        <service
            android:name=".menubar.MenuBarTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="BurnBar"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <activity
            android:name=".menubar.QuickGlanceActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="burnbar" android:host="quickglance" />
            </intent-filter>
        </activity>

        <!-- Mercury Media — incoming-call full-screen sheet. Lock-screen
             friendly so a Mac → Android call wakes the screen. -->
        <activity
            android:name=".services.media.IncomingCallActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:showOnLockScreen="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

        <!-- Mercury Media — Picture-in-Picture screen-share viewer
             survives backgrounding so the user can keep glancing at the
             Mac while replying in another app. -->
        <activity
            android:name=".ui.media.ScreenShareViewerActivity"
            android:exported="false"
            android:supportsPictureInPicture="true"
            android:resizeableActivity="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:launchMode="singleTask" />

        <!-- Mercury Media — call session foreground service. Aggregates
             microphone, camera, and (when sharing) media-projection sub
             types so a single notification covers the active call. -->
        <service
            android:name=".services.media.MediaSessionForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone|camera|mediaProjection|phoneCall" />

        <!-- Mercury Media — high-priority FCM data messages from
             `triggerVoIPCall` Cloud Function. Same envelope shape the
             iOS PushKit branch consumes. -->
        <service
            android:name=".services.media.MercuryFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>
</manifest>
