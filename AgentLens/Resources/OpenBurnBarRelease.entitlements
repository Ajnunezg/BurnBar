<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	Release signing entitlements for Developer ID distribution.

	Do not include capabilities that require a provisioning profile
	(icloud, Apple Sign In, keychain access groups) in the notarized
	release lane unless a matching Developer ID provisioning profile is
	embedded before signing.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>
</dict>
</plist>
