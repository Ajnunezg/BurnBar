{
  "name": "openburnbar-asc-setup",
  "version": "1.0.0",
  "description": "App Store Connect setup automation for OpenBurnBar",
  "scripts": {
    "setup": "node setup-asc.js",
    "setup:ios": "node setup-asc.js --platform ios",
    "status": "node asc-api.js status",
    "prepare:ios": "node asc-api.js prepare-ios",
    "attach-build": "node asc-api.js attach-build",
    "attach-internal-testflight": "node asc-api.js attach-internal-testflight",
    "beta-groups": "node asc-api.js beta-groups",
    "set-build-compliance": "node asc-api.js set-build-compliance",
    "set-manual-release": "node asc-api.js set-manual-release",
    "review-details": "node asc-api.js review-details",
    "prepare-review-metadata": "node asc-api.js prepare-review-metadata",
    "seed-review-account": "node seed-review-account.js"
  },
  "dependencies": {
    "playwright": "^1.44.0"
  }
}
