{
  "name": "openburnbar-functions",
  "version": "1.0.0",
  "description": "OpenBurnBar Cloud Functions v2 backend — provider credential vault, quota refresh, and usage rollups.",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-certs.mjs",
    "build:watch": "tsc --watch",
    "test:rollups": "npm run build && node scripts/test-rollups.mjs",
    "test:appstore": "npm run build && node scripts/test-appstore.mjs",
    "test:account-deletion": "npm run build && node scripts/test-account-deletion.mjs",
    "test:firestore-rules": "firebase emulators:exec --project openburnbar-rules-test --config ../firebase.json --only firestore \"node scripts/test-firestore-rules.mjs\"",
    "test:hermes": "npm run build && node scripts/test-hermes.mjs",
    "test:providers": "npm run build && node scripts/test-providers.mjs",
    "test": "npm run test:rollups && npm run test:appstore && npm run test:account-deletion && npm run test:hermes && npm run test:providers && npm run test:firestore-rules",
    "lint": "eslint src/**/*.ts",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.0.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.2.5",
    "googleapis": "^148.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "firebase": "^12.13.0",
    "firebase-tools": "^15.17.0",
    "typescript": "~5.7.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "fast-xml-builder": "^1.2.0"
  },
  "private": true
}
