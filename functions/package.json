{
  "name": "openburnbar-functions",
  "version": "1.0.0",
  "description": "OpenBurnBar Cloud Functions v2 backend — provider credential vault, quota refresh, and usage rollups.",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-certs.mjs",
    "build:watch": "tsc --watch",
    "test:rollups": "npm run build && node scripts/test-rollups.mjs",
    "test:appstore": "npm run build && node scripts/test-appstore.mjs",
    "test:hermes": "npm run build && node scripts/test-hermes.mjs",
    "test:providers": "npm run build && node scripts/test-providers.mjs",
    "test": "npm run test:rollups && npm run test:appstore && npm run test:hermes && npm run test:providers",
    "lint": "eslint src/**/*.ts",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.0.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0",
    "googleapis": "^148.0.0"
  },
  "devDependencies": {
    "typescript": "~5.7.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "private": true
}
