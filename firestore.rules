rules_version = '2';
// BurnBar: syncs under users/{uid}/usage, conversations, session_logs (+ chunks).
// Deploy: firebase deploy --only firestore:rules (or paste into Firebase Console → Firestore → Rules).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size() < 1048576
                   && request.resource.data.keys().size() < 50;
    }
  }
}
