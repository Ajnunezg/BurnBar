rules_version = '2';
// OpenBurnBar currently syncs explicit owner-scoped collections:
// - users/{uid}/usage, conversations, chat_threads, session_logs (+ chunks), devices
// - users/{uid}/quota_snapshots, provider_connections, provider_accounts, usage_rollups
// - users/{uid}/projects (derived read model)
// - users/{uid}/hermes_connections, hermes_pairings, hermes_relay_requests, hermes_session_cache, hermes_audit_events
// - users/{uid}/pi_agent_connections, pi_agent_pairings, pi_agent_relay_requests, pi_agent_audit_events
// - users/{uid}/provider_account_device_links, runtime_connection_preferences
// - users/{uid}/cloud_profile, sync_watermarks, sync_status, cloud_settings, recent_usage
// - users/{uid}/cloud_search_index_manifest, remote_mcp_clients, remote_mcp_grants, remote_mcp_audit_events, remote_mcp_rate_limits
// - users/{uid}/cli_sessions, cli_agent_mission_requests
// - users/{uid}/escrow_devices, escrow_public_keys, escrow_grants, escrow_envelopes, escrow_audit_events
// - server-only: provider_account_secret_refs, users/{uid}/_rate_limits, users/{uid}/rollup_jobs
// - public read-only: model_benchmark_snapshots, model_benchmark_source_status
// - workspaces/workspace-{uid}/teams/team-default/artifacts/{artifactID} (+ versions/{revisionID})
// The shared-artifact rule below intentionally stays owner-scoped for this source release.
//
// App Check: `request.auth` below is not sufficient to block non-app clients. Enforce
// App Check for Cloud Firestore in the Firebase console so only your app+attested
// traffic reaches this ruleset. See: https://firebase.google.com/docs/app-check/enable-enforcement
// and docs/FIREBASE_APP_CHECK_ENFORCEMENT.md in this repo.
//
// Escrow security: escrow_envelopes MUST contain ciphertext only. The rules below
// reject documents that contain field names associated with plaintext credentials.
// Client code is independently responsible for ensuring plaintext secrets are never
// serialized into Firestore documents (validated by unit tests).
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function requestWithinBasicLimits() {
      return request.resource.size() < 1048576
        && request.resource.data.keys().size() < 80;
    }

    function escrowDocumentLimits() {
      return request.resource.size() < 51200
        && request.resource.data.keys().size() < 20;
    }

    function ownsUserNamespace(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasNoPlaintextSecretFields() {
      return !("apiKey" in request.resource.data)
        && !("token" in request.resource.data)
        && !("refreshToken" in request.resource.data)
        && !("accessToken" in request.resource.data)
        && !("idToken" in request.resource.data)
        && !("cookie" in request.resource.data)
        && !("password" in request.resource.data)
        && !("secret" in request.resource.data)
        && !("secretVersionName" in request.resource.data)
        && !("authorization" in request.resource.data)
        && !("bearer" in request.resource.data)
        && !("credential" in request.resource.data);
    }

    function ownerWritableNonSecret(userId) {
      return ownsUserNamespace(userId)
        && requestWithinBasicLimits()
        && hasNoPlaintextSecretFields();
    }

    function validPixelClockConfig(pixelClock) {
      return pixelClock is map
        && pixelClock.keys().hasOnly([
          "enabled",
          "host",
          "port",
          "layout",
          "palette",
          "timePeriod",
          "workingSpinnerStyle",
          "workingSpinnerPrimaryHex",
          "workingSpinnerSecondaryHex",
          "completionClockSoundEnabled",
          "completionLocalNotificationsEnabled",
          "pageDurationSeconds",
          "updateIntervalSeconds",
          "scrollSpeedPercent",
          "brightness",
          "providerIDs",
          "updatedAt",
          "updatedByDeviceId",
          "lastProbeStatus"
        ])
        && pixelClock.enabled is bool
        && pixelClock.host is string
        && pixelClock.host.size() <= 255
        && pixelClock.port is int
        && pixelClock.port >= 1
        && pixelClock.port <= 65535
        && pixelClock.layout in ["providerDashboard", "quotaCarousel", "burnStatus", "alertsOnly"]
        && pixelClock.palette in ["emberWhimsy", "mercury", "traffic", "monochrome"]
        && pixelClock.timePeriod in ["rolling5h", "rolling24h", "rolling7d", "rolling30d"]
        && (!("workingSpinnerStyle" in pixelClock) || pixelClock.workingSpinnerStyle in ["orbit", "chase", "pulse", "scan"])
        && (!("workingSpinnerPrimaryHex" in pixelClock) || (pixelClock.workingSpinnerPrimaryHex is string && pixelClock.workingSpinnerPrimaryHex.matches("^#[0-9A-Fa-f]{6}$")))
        && (!("workingSpinnerSecondaryHex" in pixelClock) || (pixelClock.workingSpinnerSecondaryHex is string && pixelClock.workingSpinnerSecondaryHex.matches("^#[0-9A-Fa-f]{6}$")))
        && (!("completionClockSoundEnabled" in pixelClock) || pixelClock.completionClockSoundEnabled is bool)
        && (!("completionLocalNotificationsEnabled" in pixelClock) || pixelClock.completionLocalNotificationsEnabled is bool)
        && pixelClock.pageDurationSeconds is int
        && pixelClock.pageDurationSeconds >= 3
        && pixelClock.pageDurationSeconds <= 30
        && pixelClock.updateIntervalSeconds is int
        && pixelClock.updateIntervalSeconds >= 15
        && pixelClock.updateIntervalSeconds <= 3600
        && pixelClock.scrollSpeedPercent is int
        && pixelClock.scrollSpeedPercent >= 10
        && pixelClock.scrollSpeedPercent <= 300
        && (!("brightness" in pixelClock) || (
          pixelClock.brightness is int
          && pixelClock.brightness >= 0
          && pixelClock.brightness <= 255
        ))
        && pixelClock.providerIDs is list
        && pixelClock.providerIDs.size() <= 24
        && pixelClock.lastProbeStatus in ["unknown", "awtrixReady", "stockUlanziFirmware", "unreachable", "unsupported", "error"]
        && (!("updatedByDeviceId" in pixelClock) || (pixelClock.updatedByDeviceId is string && pixelClock.updatedByDeviceId.size() <= 160));
    }

    function validSmartHubDisplayConfig(displayConfig) {
      return displayConfig is map
        && displayConfig.keys().hasOnly([
          "layout",
          "palette",
          "theme",
          "background",
          "brightness",
          "scrollSpeedSeconds",
          "refreshCadenceSeconds",
          "providerIDs",
          "audibleCue",
          "identifyOnRefresh",
          "updatedAt"
        ])
        && displayConfig.layout in ["quotaCarousel", "bigTotal", "providerGrid", "singleProvider"]
        && displayConfig.palette in ["emberWhimsy", "mercury", "forestSage", "monochrome"]
        && displayConfig.theme in ["warmCharcoal", "botanicalCream", "oledBlack", "matchSystem"]
        && displayConfig.background in ["dashboard", "ambient", "photoBlend"]
        && displayConfig.brightness is number
        && displayConfig.brightness >= 0.2
        && displayConfig.brightness <= 1.0
        && displayConfig.scrollSpeedSeconds is int
        && displayConfig.scrollSpeedSeconds >= 3
        && displayConfig.scrollSpeedSeconds <= 30
        && displayConfig.refreshCadenceSeconds is int
        && displayConfig.refreshCadenceSeconds >= 3
        && displayConfig.refreshCadenceSeconds <= 60
        && displayConfig.providerIDs is list
        && displayConfig.providerIDs.size() <= 24
        && displayConfig.audibleCue is bool
        && displayConfig.identifyOnRefresh is bool
        && displayConfig.updatedAt is string
        && displayConfig.updatedAt.size() <= 64;
    }

    function validSmartDisplayOrder(displayOrder) {
      return displayOrder is list
        && displayOrder.size() <= 4
        && displayOrder.hasOnly(["nestHub", "pixelClock"]);
    }

    function hostedCloudEntitlementPath(userId) {
      return /databases/$(database)/documents/users/$(userId)/entitlements/hosted_quota_sync;
    }

    function burnBarProEntitlementPath(userId) {
      return /databases/$(database)/documents/users/$(userId)/entitlements/burnbar_pro;
    }

    function activePremiumEntitlementData(entitlement) {
      return entitlement.active == true
        && entitlement.productID in [
          "com.openburnbar.hostedQuotaSync.cloud.monthly",
          "com.openburnbar.hostedQuotaSync.monthly",
          "com.openburnbar.pro.monthly"
        ]
        && entitlement.expireAt is timestamp
        && entitlement.expireAt > request.time;
    }

    function hasActiveHostedQuotaEntitlement(userId) {
      return (
          exists(hostedCloudEntitlementPath(userId))
          && activePremiumEntitlementData(get(hostedCloudEntitlementPath(userId)).data)
        )
        || (
          exists(burnBarProEntitlementPath(userId))
          && activePremiumEntitlementData(get(burnBarProEntitlementPath(userId)).data)
        );
    }

    function ownerWritableHostedCloudBackup(userId) {
      return ownerWritableNonSecret(userId)
        && hasActiveHostedQuotaEntitlement(userId);
    }

    function ownerWritableSessionLogManifest(userId) {
      return ownerWritableHostedCloudBackup(userId)
        && !("body" in request.resource.data)
        && !("payloadCiphertext" in request.resource.data)
        && !("ciphertext" in request.resource.data)
        && !("data" in request.resource.data)
        && !("text" in request.resource.data);
    }

    function ownerWritableSessionLogChunk(userId) {
      return ownerWritableHostedCloudBackup(userId)
        && !("body" in request.resource.data)
        && !("payloadCiphertext" in request.resource.data)
        && !("ciphertext" in request.resource.data)
        && !("data" in request.resource.data)
        && !("text" in request.resource.data);
    }

    function validCloudHexDigest(value) {
      return value is string
        && value.matches("^[a-f0-9]{32,128}$");
    }

    function validCloudSealedText(value) {
      return value is map
        && value.keys().hasAll([
          "algorithm",
          "keyVersion",
          "nonce",
          "ciphertext",
          "tag"
        ])
        && value.keys().hasOnly([
          "algorithm",
          "keyVersion",
          "nonce",
          "ciphertext",
          "tag"
        ])
        && value.algorithm == "AES-256-GCM"
        && value.keyVersion is int
        && value.keyVersion >= 1
        && value.keyVersion <= 100
        && value.nonce is string
        && value.nonce.size() <= 128
        && value.nonce.matches("^[A-Za-z0-9+/=]+$")
        && value.ciphertext is string
        && value.ciphertext.size() <= 8192
        && value.ciphertext.matches("^[A-Za-z0-9+/=]+$")
        && value.tag is string
        && value.tag.size() <= 128
        && value.tag.matches("^[A-Za-z0-9+/=]+$");
    }

    function validCloudSessionStoragePath(userId, documentId, bodyHash, storagePath) {
      return validCloudHexDigest(bodyHash)
        && storagePath is string
        && storagePath.matches("^users/" + userId + "/session_logs/" + documentId + "/bodies/" + bodyHash + "\\.json\\.aesgcm$");
    }

    function validCloudSearchHashes(value) {
      return value is list
        && value.size() > 0
        && value.size() <= 250;
    }

    function chatThreadIncludesBackedUpContent() {
      return request.resource.data.keys().hasAny(["messages", "title", "preview"])
        || (("contentIncluded" in request.resource.data)
          && request.resource.data.contentIncluded == true);
    }

    function ownerWritableChatThread(userId) {
      return ownerWritableNonSecret(userId)
        && (!chatThreadIncludesBackedUpContent()
          || hasActiveHostedQuotaEntitlement(userId));
    }

    function relayConnectionWrite(userId, connectionId) {
      return ownerWritableNonSecret(userId)
        && hasActiveHostedQuotaEntitlement(userId)
        && request.resource.data.keys().hasOnly([
          "id",
          "displayName",
          "mode",
          "status",
          "profileName",
          "advertisedModel",
          "relayPublicKey",
          "relayKeyVersion",
          "relayEncryption",
          "realtimeRelayURL",
          "realtimeRelayStatus",
          "realtimeRelayLastSeenAt",
          "realtimeRelayProtocolVersion",
          "capabilities",
          "lastSeenAt",
          "createdAt",
          "updatedAt",
          "schemaVersion"
        ])
        && request.resource.data.mode == "relayLink"
        && request.resource.data.status in ["online", "offline", "degraded", "unauthorized"]
        && request.resource.data.schemaVersion is int
        && (!("relayPublicKey" in request.resource.data) || (request.resource.data.relayPublicKey is string && request.resource.data.relayPublicKey.size() <= 256))
        && (!("relayKeyVersion" in request.resource.data) || request.resource.data.relayKeyVersion is int)
        && (!("relayEncryption" in request.resource.data) || request.resource.data.relayEncryption == "p256-hkdf-sha256-aesgcm")
        && (!("realtimeRelayURL" in request.resource.data) || (request.resource.data.realtimeRelayURL is string && request.resource.data.realtimeRelayURL.matches("^wss://.+")))
        && (!("realtimeRelayStatus" in request.resource.data) || request.resource.data.realtimeRelayStatus in ["online", "offline", "degraded"])
        && (!("realtimeRelayLastSeenAt" in request.resource.data) || (request.resource.data.realtimeRelayLastSeenAt is string && request.resource.data.realtimeRelayLastSeenAt.size() <= 64))
        && (!("realtimeRelayProtocolVersion" in request.resource.data) || request.resource.data.realtimeRelayProtocolVersion is int)
        && request.resource.data.id is string
        && request.resource.data.id == connectionId
        && request.resource.data.displayName is string
        && request.resource.data.capabilities is list;
    }

    function relayRequestWrite(userId, requestId) {
      return ownerWritableNonSecret(userId)
        && hasActiveHostedQuotaEntitlement(userId)
        && request.resource.data.keys().hasOnly([
          "id",
          "connectionId",
          "operation",
          "status",
          "method",
          "path",
          "sessionId",
          "body",
          "payloadCiphertext",
          "wrappedKey",
          "relayEncryption",
          "relayKeyVersion",
          "error",
          "chunkCount",
          "createdAt",
          "updatedAt",
          "expiresAt",
          "expireAt",
          "claimedAt",
          "claimedBy",
          "completedAt",
          "schemaVersion"
        ])
        && request.resource.data.id is string
        && request.resource.data.id == requestId
        && request.resource.data.connectionId is string
        && request.resource.data.operation in ["chatCompletions", "models", "sessions", "sessionDetail", "profiles", "jobs"]
        && request.resource.data.status in ["pending", "claimed", "streaming", "completed", "failed", "cancelled", "expired"]
        && request.resource.data.method in ["GET", "POST"]
        && request.resource.data.chunkCount is int
        && request.resource.data.schemaVersion is int
        && (!("claimedBy" in request.resource.data) || request.resource.data.claimedBy == request.resource.data.connectionId)
        && (!("body" in request.resource.data) || (request.resource.data.body is string && request.resource.data.body.size() <= 131072))
        && (!("error" in request.resource.data) || (request.resource.data.error is string && request.resource.data.error.size() <= 2048))
        && (!("payloadCiphertext" in request.resource.data) || (request.resource.data.payloadCiphertext is string && request.resource.data.payloadCiphertext.size() <= 900000))
        && (!("wrappedKey" in request.resource.data) || (request.resource.data.wrappedKey is string && request.resource.data.wrappedKey.size() <= 4096))
        && (!("relayKeyVersion" in request.resource.data) || request.resource.data.relayKeyVersion is int)
        && (!("relayEncryption" in request.resource.data) || request.resource.data.relayEncryption == "p256-hkdf-sha256-aesgcm")
        && (
          request.resource.data.schemaVersion < 2
          || (
            !("path" in request.resource.data)
            && !("sessionId" in request.resource.data)
            && !("body" in request.resource.data)
            && !("error" in request.resource.data)
            && request.resource.data.payloadCiphertext is string
            && request.resource.data.wrappedKey is string
            && request.resource.data.relayEncryption == "p256-hkdf-sha256-aesgcm"
          )
        );
    }

    function relayChunkWrite(userId, requestId, chunkId) {
      return ownerWritableNonSecret(userId)
        && hasActiveHostedQuotaEntitlement(userId)
        && request.resource.data.keys().hasOnly([
          "id",
          "requestId",
          "sequence",
          "kind",
          "data",
          "text",
          "error",
          "ciphertext",
          "createdAt",
          "updatedAt",
          "schemaVersion"
        ])
        && request.resource.data.id is string
        && request.resource.data.id == chunkId
        && request.resource.data.requestId is string
        && request.resource.data.requestId == requestId
        && request.resource.data.sequence is int
        && request.resource.data.kind in ["sse", "data", "error"]
        && request.resource.data.schemaVersion is int
        && (!("data" in request.resource.data) || (request.resource.data.data is string && request.resource.data.data.size() <= 131072))
        && (!("text" in request.resource.data) || (request.resource.data.text is string && request.resource.data.text.size() <= 131072))
        && (!("error" in request.resource.data) || (request.resource.data.error is string && request.resource.data.error.size() <= 2048))
        && (!("ciphertext" in request.resource.data) || (request.resource.data.ciphertext is string && request.resource.data.ciphertext.size() <= 131072))
        && (
          request.resource.data.schemaVersion < 2
          || (
            !("data" in request.resource.data)
            && !("text" in request.resource.data)
            && !("error" in request.resource.data)
            && request.resource.data.ciphertext is string
          )
        );
    }

    function piRelayConnectionWrite(userId, connectionId) {
      return ownerWritableNonSecret(userId)
        && hasActiveHostedQuotaEntitlement(userId)
        && request.resource.data.keys().hasOnly([
          "id",
          "displayName",
          "mode",
          "status",
          "endpointURL",
          "advertisedModel",
          "selectedInstanceID",
          "redisURL",
          "relayPublicKey",
          "relayKeyVersion",
          "relayEncryption",
          "realtimeRelayURL",
          "realtimeRelayStatus",
          "realtimeRelayLastSeenAt",
          "realtimeRelayProtocolVersion",
          "capabilities",
          "instances",
          "models",
          "lastSeenAt",
          "createdAt",
          "updatedAt",
          "schemaVersion"
        ])
        && request.resource.data.mode == "relayLink"
        && request.resource.data.status in ["online", "offline", "degraded", "unauthorized"]
        && request.resource.data.schemaVersion is int
        && request.resource.data.id is string
        && request.resource.data.id == connectionId
        && request.resource.data.displayName is string
        && request.resource.data.capabilities is list
        && (!("endpointURL" in request.resource.data) || (request.resource.data.endpointURL is string && request.resource.data.endpointURL.size() <= 2048))
        && (!("advertisedModel" in request.resource.data) || (request.resource.data.advertisedModel is string && request.resource.data.advertisedModel.size() <= 160))
        && (!("selectedInstanceID" in request.resource.data) || (request.resource.data.selectedInstanceID is string && request.resource.data.selectedInstanceID.size() <= 160))
        && (!("redisURL" in request.resource.data) || (request.resource.data.redisURL is string && request.resource.data.redisURL.size() <= 2048))
        && (!("relayPublicKey" in request.resource.data) || (request.resource.data.relayPublicKey is string && request.resource.data.relayPublicKey.size() <= 256))
        && (!("relayKeyVersion" in request.resource.data) || request.resource.data.relayKeyVersion is int)
        && (!("relayEncryption" in request.resource.data) || request.resource.data.relayEncryption == "p256-hkdf-sha256-aesgcm")
        && (!("realtimeRelayURL" in request.resource.data) || (request.resource.data.realtimeRelayURL is string && request.resource.data.realtimeRelayURL.matches("^wss://.+")))
        && (!("realtimeRelayStatus" in request.resource.data) || request.resource.data.realtimeRelayStatus in ["online", "offline", "degraded"]);
    }

    function piRelayRequestWrite(userId, requestId) {
      return ownerWritableNonSecret(userId)
        && hasActiveHostedQuotaEntitlement(userId)
        && request.resource.data.keys().hasOnly([
          "id",
          "connectionId",
          "operation",
          "status",
          "method",
          "payloadCiphertext",
          "wrappedKey",
          "relayEncryption",
          "relayKeyVersion",
          "chunkCount",
          "createdAt",
          "updatedAt",
          "expiresAt",
          "expireAt",
          "claimedAt",
          "claimedBy",
          "completedAt",
          "schemaVersion"
        ])
        && request.resource.data.id is string
        && request.resource.data.id == requestId
        && request.resource.data.connectionId is string
        && request.resource.data.operation in ["chatCompletions", "models", "sessions", "sessionDetail"]
        && request.resource.data.status in ["pending", "claimed", "streaming", "completed", "failed", "cancelled", "expired"]
        && request.resource.data.method in ["GET", "POST"]
        && request.resource.data.chunkCount is int
        && request.resource.data.schemaVersion is int
        && request.resource.data.schemaVersion >= 2
        && request.resource.data.payloadCiphertext is string
        && request.resource.data.payloadCiphertext.size() <= 900000
        && request.resource.data.wrappedKey is string
        && request.resource.data.wrappedKey.size() <= 4096
        && request.resource.data.relayEncryption == "p256-hkdf-sha256-aesgcm"
        && request.resource.data.relayKeyVersion is int
        && (!("claimedBy" in request.resource.data) || request.resource.data.claimedBy == request.resource.data.connectionId);
    }

    function piRelayChunkWrite(userId, requestId, chunkId) {
      return ownerWritableNonSecret(userId)
        && hasActiveHostedQuotaEntitlement(userId)
        && request.resource.data.keys().hasOnly([
          "id",
          "requestId",
          "sequence",
          "kind",
          "ciphertext",
          "createdAt",
          "updatedAt",
          "schemaVersion"
        ])
        && request.resource.data.id is string
        && request.resource.data.id == chunkId
        && request.resource.data.requestId is string
        && request.resource.data.requestId == requestId
        && request.resource.data.sequence is int
        && request.resource.data.kind in ["sse", "data", "error"]
        && request.resource.data.schemaVersion is int
        && request.resource.data.schemaVersion >= 2
        && request.resource.data.ciphertext is string
        && request.resource.data.ciphertext.size() <= 131072;
    }

    function runtimeConnectionPreferenceWrite(userId, preferenceId) {
      return ownerWritableNonSecret(userId)
        && request.resource.data.keys().hasOnly([
          "id",
          "deviceID",
          "runtimeKind",
          "selectedConnectionID",
          "selectedInstanceID",
          "selectedModelID",
          "createdAt",
          "updatedAt",
          "schemaVersion"
        ])
        && request.resource.data.id is string
        && request.resource.data.id == preferenceId
        && request.resource.data.deviceID is string
        && request.resource.data.deviceID.size() <= 160
        && request.resource.data.runtimeKind in ["hermes", "piAgent"]
        && preferenceId == request.resource.data.deviceID + "_" + request.resource.data.runtimeKind
        && request.resource.data.selectedConnectionID is string
        && request.resource.data.selectedConnectionID.size() <= 160
        && (!("selectedInstanceID" in request.resource.data) || (request.resource.data.selectedInstanceID is string && request.resource.data.selectedInstanceID.size() <= 160))
        && (!("selectedModelID" in request.resource.data) || (request.resource.data.selectedModelID is string && request.resource.data.selectedModelID.size() <= 240))
        && request.resource.data.schemaVersion is int;
    }

    function sharedArtifactOwnerRead() {
      return isSignedIn()
        && resource.data.ownerUserID is string
        && resource.data.ownerUserID == request.auth.uid;
    }

    function sharedArtifactOwnerWrite(workspaceId, teamId) {
      return isSignedIn()
        && requestWithinBasicLimits()
        && request.resource.data.ownerUserID is string
        && request.resource.data.ownerUserID == request.auth.uid
        && request.resource.data.workspaceID == workspaceId
        && request.resource.data.teamID == teamId;
    }

    // --- Server-only private provider credential references ---

    // Cloud Functions store Secret Manager version names here. The Admin SDK
    // bypasses rules; clients must never read or write these documents.
    match /provider_account_secret_refs/{refId} {
      allow read, write: if false;
    }

    // --- Public read-only model-landscape metadata ---

    match /model_benchmark_snapshots/{snapshotId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /model_benchmark_source_status/{sourceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- User-scoped data ---

    match /users/{userId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if ownsUserNamespace(userId) && requestWithinBasicLimits();
    }

    match /users/{userId}/usage/{usageId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId);
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/conversations/{conversationId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableHostedCloudBackup(userId);
      allow delete: if false;
    }

    match /users/{userId}/chat_threads/{threadId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableChatThread(userId);
      allow delete: if ownsUserNamespace(userId);
    }

    // Mobile assistant chat history (Hermes + Pi conversations originated on
    // an iOS device). Owner-only with no entitlement gate — the same data is
    // also persisted on-device, so Firestore is the cross-device mirror.
    match /users/{userId}/mobile_assistant_chats/{threadId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId);
      allow delete: if ownsUserNamespace(userId);
    }

    // Mac CLI agent transcripts mirrored for the mobile Assistants tiles.
    match /users/{userId}/cli_sessions/{sessionId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId)
        && request.resource.data.keys().hasOnly([
          "id",
          "agent",
          "title",
          "preview",
          "modelName",
          "workspaceLabel",
          "createdAt",
          "updatedAt",
          "endedAt",
          "schemaVersion",
          "messages",
          "tokenUsage"
        ])
        && request.resource.data.id is string
        && request.resource.data.id.size() <= 512
        && request.resource.data.agent in ["codex", "claude", "openclaw"]
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 512
        && request.resource.data.preview is string
        && request.resource.data.preview.size() <= 2048
        && request.resource.data.schemaVersion is int
        && (!("modelName" in request.resource.data) || (request.resource.data.modelName is string && request.resource.data.modelName.size() <= 256))
        && (!("workspaceLabel" in request.resource.data) || (request.resource.data.workspaceLabel is string && request.resource.data.workspaceLabel.size() <= 512))
        && (!("messages" in request.resource.data) || (request.resource.data.messages is list && request.resource.data.messages.size() <= 200));
      allow delete: if ownsUserNamespace(userId);
    }

    // Mobile Insights mission dispatch. iOS/iPadOS/Android create pending
    // requests; the signed-in Mac claims them, runs the local agent, then
    // writes status and a small preview back for mobile.
    match /users/{userId}/cli_agent_mission_requests/{requestId} {
      function validCliAgentMissionRequest() {
        return request.resource.data.keys().hasOnly([
          "id",
          "title",
          "prompt",
          "missionKind",
          "requestedRuntime",
          "targetProject",
          "depth",
          "approvalMode",
          "commandsAllowed",
          "fileEditsAllowed",
          "source",
          "status",
          "createdAt",
          "updatedAt",
          "startedAt",
          "completedAt",
          "claimedBy",
          "selectedRuntime",
          "selectedRuntimeName",
          "sessionId",
          "approvalRequestId",
          "approvalStatus",
          "approvalRequestedAt",
          "approvalRespondedAt",
          "approvalTitle",
          "approvalMessage",
          "liveSummary",
          "events",
          "resultPreview",
          "errorMessage",
          "lastEventSequence",
          "schemaVersion",
          // Hermes Square Phase B — group + persona hints. All optional;
          // server-side enforcement still pins the existing-field invariants.
          "groupID",
          "siblingIndex",
          "siblingCount",
          "isGroupChild",
          "personaScopeJSON",
          "personaID"
        ])
        && request.resource.data.id is string
        && request.resource.data.id.size() <= 512
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 512
        && request.resource.data.prompt is string
        && request.resource.data.prompt.size() <= 20000
        && request.resource.data.missionKind in ["debt", "diligence", "creative", "accretive", "security", "ui_improvement", "modernization", "provider_routing", "cost_efficiency", "project_focus", "custom"]
        && request.resource.data.requestedRuntime in ["auto", "codex", "claude", "hermes", "openclaw", "piAgent", "pi", "opencode", "ollama"]
        && request.resource.data.source in ["ios-insights", "android-insights", "mac-insights"]
        && request.resource.data.status in ["pending", "queued", "accepted", "starting", "running", "waiting_for_approval", "completed", "failed", "canceled", "cancelled", "mac_offline", "unauthorized", "agent_launch_failed"]
        && request.resource.data.schemaVersion is int
        && (!("targetProject" in request.resource.data) || (request.resource.data.targetProject is string && request.resource.data.targetProject.size() <= 512))
        && (!("depth" in request.resource.data) || request.resource.data.depth in ["light", "standard", "deep", "max"])
        && (!("approvalMode" in request.resource.data) || request.resource.data.approvalMode in ["existing_policy", "manual_all", "risky_only", "read_only"])
        && (!("commandsAllowed" in request.resource.data) || request.resource.data.commandsAllowed is bool)
        && (!("fileEditsAllowed" in request.resource.data) || request.resource.data.fileEditsAllowed is bool)
        && (!("claimedBy" in request.resource.data) || (request.resource.data.claimedBy is string && request.resource.data.claimedBy.size() <= 256))
        && (!("selectedRuntime" in request.resource.data) || request.resource.data.selectedRuntime in ["codex", "claude", "hermes", "openclaw", "piAgent", "pi", "opencode", "ollama"])
        && (!("selectedRuntimeName" in request.resource.data) || (request.resource.data.selectedRuntimeName is string && request.resource.data.selectedRuntimeName.size() <= 80))
        && (!("sessionId" in request.resource.data) || (request.resource.data.sessionId is string && request.resource.data.sessionId.size() <= 512))
        && (!("approvalRequestId" in request.resource.data) || (request.resource.data.approvalRequestId is string && request.resource.data.approvalRequestId.size() <= 512))
        && (!("approvalStatus" in request.resource.data) || request.resource.data.approvalStatus in ["pending", "approved", "rejected", "canceled", "cancelled"])
        && (!("approvalRequestedAt" in request.resource.data) || (request.resource.data.approvalRequestedAt is string && request.resource.data.approvalRequestedAt.size() <= 80))
        && (!("approvalRespondedAt" in request.resource.data) || (request.resource.data.approvalRespondedAt is string && request.resource.data.approvalRespondedAt.size() <= 80))
        && (!("approvalTitle" in request.resource.data) || (request.resource.data.approvalTitle is string && request.resource.data.approvalTitle.size() <= 512))
        && (!("approvalMessage" in request.resource.data) || (request.resource.data.approvalMessage is string && request.resource.data.approvalMessage.size() <= 2048))
        && (!("liveSummary" in request.resource.data) || (request.resource.data.liveSummary is string && request.resource.data.liveSummary.size() <= 2048))
        && (!("events" in request.resource.data) || (request.resource.data.events is list && request.resource.data.events.size() <= 300))
        && (!("resultPreview" in request.resource.data) || (request.resource.data.resultPreview is string && request.resource.data.resultPreview.size() <= 2048))
        && (!("errorMessage" in request.resource.data) || (request.resource.data.errorMessage is string && request.resource.data.errorMessage.size() <= 2048))
        && (!("lastEventSequence" in request.resource.data) || request.resource.data.lastEventSequence is int)
        // Hermes Square Phase B — group/persona hint validators (all optional)
        && (!("groupID" in request.resource.data) || (request.resource.data.groupID is string && request.resource.data.groupID.size() <= 128))
        && (!("siblingIndex" in request.resource.data) || (request.resource.data.siblingIndex is int && request.resource.data.siblingIndex >= 0 && request.resource.data.siblingIndex < 16))
        && (!("siblingCount" in request.resource.data) || (request.resource.data.siblingCount is int && request.resource.data.siblingCount > 0 && request.resource.data.siblingCount <= 16))
        && (!("isGroupChild" in request.resource.data) || request.resource.data.isGroupChild is bool)
        && (!("personaScopeJSON" in request.resource.data) || (request.resource.data.personaScopeJSON is string && request.resource.data.personaScopeJSON.size() <= 8192))
        && (!("personaID" in request.resource.data) || (request.resource.data.personaID is string && request.resource.data.personaID.size() <= 128));
      }

      function validCliAgentMissionCreate() {
        return request.resource.data.status == "pending"
          && request.resource.data.source in ["ios-insights", "android-insights", "mac-insights"]
          && request.resource.data.prompt.size() > 0
          && !("startedAt" in request.resource.data)
          && !("completedAt" in request.resource.data)
          && !("claimedBy" in request.resource.data)
          && !("selectedRuntime" in request.resource.data)
          && !("selectedRuntimeName" in request.resource.data)
          && !("sessionId" in request.resource.data)
          && !("approvalRequestId" in request.resource.data)
          && !("approvalStatus" in request.resource.data)
          && !("approvalRequestedAt" in request.resource.data)
          && !("approvalRespondedAt" in request.resource.data)
          && !("approvalTitle" in request.resource.data)
          && !("approvalMessage" in request.resource.data)
          && !("events" in request.resource.data)
          && !("resultPreview" in request.resource.data)
          && !("errorMessage" in request.resource.data)
          && !("lastEventSequence" in request.resource.data);
      }

      function trustedMissionExecutorDevice(userId) {
        return ("claimedBy" in request.resource.data)
          && exists(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(request.resource.data.claimedBy))
          && get(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(request.resource.data.claimedBy)).data.trustState == "trusted"
          && get(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(request.resource.data.claimedBy)).data.platform == "macOS";
      }

      function validTrustedMissionHostUpdate(userId) {
        return trustedMissionExecutorDevice(userId)
          && (!("claimedBy" in resource.data) || request.resource.data.claimedBy == resource.data.claimedBy)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["events"]);
      }

      function validMobileMissionApprovalResponse() {
        return resource.data.status == "waiting_for_approval"
          && request.resource.data.status == "waiting_for_approval"
          && request.resource.data.approvalStatus in ["approved", "rejected", "canceled", "cancelled"]
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "approvalStatus",
            "approvalRespondedAt",
            "liveSummary",
            "updatedAt"
          ]);
      }

      function validMissionRefusalOrFailureUpdate() {
        return resource.data.status in ["unauthorized", "failed", "canceled", "cancelled"]
          && request.resource.data.status == resource.data.status
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "lastEventSequence",
            "liveSummary",
            "updatedAt"
          ]);
      }

      function trustedMissionExecutorClaim(userId, requestId) {
        return exists(/databases/$(database)/documents/users/$(userId)/cli_agent_mission_requests/$(requestId))
          && ("claimedBy" in get(/databases/$(database)/documents/users/$(userId)/cli_agent_mission_requests/$(requestId)).data)
          && exists(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(get(/databases/$(database)/documents/users/$(userId)/cli_agent_mission_requests/$(requestId)).data.claimedBy))
          && get(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(get(/databases/$(database)/documents/users/$(userId)/cli_agent_mission_requests/$(requestId)).data.claimedBy)).data.trustState == "trusted"
          && get(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(get(/databases/$(database)/documents/users/$(userId)/cli_agent_mission_requests/$(requestId)).data.claimedBy)).data.platform == "macOS";
      }

      function validCliAgentMissionEventSource(userId, requestId, eventId) {
        return (
            request.resource.data.source in ["ios", "android"]
            && request.resource.data.phase == "queued"
            && request.resource.data.kind == "status"
            && request.resource.data.sequence == 1
            && eventId == "000001"
          )
          || (
            request.resource.data.source == "mac"
            && trustedMissionExecutorClaim(userId, requestId)
          );
      }

      allow read: if ownsUserNamespace(userId);
      allow create: if ownerWritableNonSecret(userId)
        && validCliAgentMissionRequest()
        && validCliAgentMissionCreate();
      allow update: if ownerWritableNonSecret(userId)
        && validCliAgentMissionRequest()
        && (
          validTrustedMissionHostUpdate(userId)
          || validMobileMissionApprovalResponse()
          || validMissionRefusalOrFailureUpdate()
        );
      allow delete: if false;

      match /events/{eventId} {
        allow read: if ownsUserNamespace(userId);
        allow create: if ownerWritableNonSecret(userId)
          && request.resource.data.keys().hasOnly([
            "sequence",
            "timestamp",
            "kind",
            "phase",
            "title",
            "message",
            "fullMessage",
            "messageLength",
            "messageTruncated",
            "runtime",
            "source",
            "toolName",
            "artifactPath",
            "changedFilePath",
            "isError"
          ])
          && request.resource.data.sequence is int
          && request.resource.data.sequence >= 1
          && request.resource.data.timestamp is string
          && request.resource.data.timestamp.size() <= 80
          && request.resource.data.kind in ["status", "llm_response", "assistant_message", "tool_call", "tool_result", "error", "approval_request", "artifact", "changed_file", "final_answer"]
          && request.resource.data.phase in ["queued", "accepted", "claimed", "starting", "running", "streaming", "assistant_response", "tool_use", "tool_result", "waiting_for_approval", "approval_requested", "approval_resolved", "artifact", "changed_file", "completed", "failed", "canceled", "cancelled", "mac_offline", "unauthorized", "agent_launch_failed", "process_started", "process_running"]
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 160
          && request.resource.data.message is string
          && request.resource.data.message.size() <= 2048
          && (!("fullMessage" in request.resource.data) || (
            request.resource.data.fullMessage is string
            && request.resource.data.fullMessage.size() <= 24000
          ))
          && (!("messageLength" in request.resource.data) || (
            request.resource.data.messageLength is int
            && request.resource.data.messageLength >= request.resource.data.message.size()
            && request.resource.data.messageLength <= 24000
          ))
          && (!("messageTruncated" in request.resource.data) || request.resource.data.messageTruncated is bool)
          && request.resource.data.source in ["ios", "android", "mac"]
          && validCliAgentMissionEventSource(userId, requestId, eventId)
          && request.resource.data.isError is bool
          && (!("runtime" in request.resource.data) || request.resource.data.runtime in ["codex", "claude", "hermes", "openclaw", "piAgent", "pi", "opencode", "ollama", "auto"])
          && (!("toolName" in request.resource.data) || (request.resource.data.toolName is string && request.resource.data.toolName.size() <= 160))
          && (!("artifactPath" in request.resource.data) || (request.resource.data.artifactPath is string && request.resource.data.artifactPath.size() <= 512))
          && (!("changedFilePath" in request.resource.data) || (request.resource.data.changedFilePath is string && request.resource.data.changedFilePath.size() <= 512));
        allow update, delete: if false;
      }
    }

    // Hermes Square Phase B — mission groups (fan-out parent). Owner writes
    // the parent document at dispatch, the Mac listener stamps phase
    // transitions, the phone observes both.
    match /users/{userId}/mission_groups/{groupId} {
      function validMissionGroup() {
        return request.resource.data.keys().hasOnly([
          "id", "title", "prompt", "missionKind", "targetProject",
          "childMissionIDs", "runtimeTokens", "parallelismLimit",
          "mergeStrategy", "phase", "winnerMissionID",
          "forecast", "createdAt", "updatedAt", "schemaVersion", "source",
          "synthesisSummary"
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 512
        && request.resource.data.prompt is string
        && request.resource.data.prompt.size() <= 20000
        && request.resource.data.childMissionIDs is list
        && request.resource.data.childMissionIDs.size() <= 16
        && request.resource.data.runtimeTokens is list
        && request.resource.data.runtimeTokens.size() <= 16
        && request.resource.data.parallelismLimit is int
        && request.resource.data.parallelismLimit >= 1
        && request.resource.data.parallelismLimit <= 16
        && request.resource.data.mergeStrategy in ["pick_one", "keep_all", "synthesize"]
        && request.resource.data.phase in ["queued", "fanning_out", "awaiting_merge", "merged", "cancelled", "failed"]
        && request.resource.data.schemaVersion is int;
      }
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId) && validMissionGroup();
      allow delete: if ownsUserNamespace(userId);
    }

    // Hermes Square Phase B — class-based approval policies. Phone writes,
    // phone reads. Synced across devices via the user namespace.
    match /users/{userId}/approval_policies/{policyId} {
      function validApprovalPolicy() {
        return request.resource.data.keys().hasOnly([
          "id", "displayLabel", "decision", "missionKind", "toolName",
          "fileGlob", "runtimeID", "targetProject", "createdAt",
          "expiresAt", "matchCount", "schemaVersion"
        ])
        && request.resource.data.decision in ["approve", "deny"]
        && request.resource.data.displayLabel is string
        && request.resource.data.displayLabel.size() <= 256
        && (!("missionKind" in request.resource.data) || request.resource.data.missionKind is string)
        && (!("toolName" in request.resource.data) || request.resource.data.toolName is string)
        && (!("fileGlob" in request.resource.data) || (request.resource.data.fileGlob is string && request.resource.data.fileGlob.size() <= 256))
        && (!("runtimeID" in request.resource.data) || request.resource.data.runtimeID is string)
        && (!("targetProject" in request.resource.data) || (request.resource.data.targetProject is string && request.resource.data.targetProject.size() <= 512))
        && (!("matchCount" in request.resource.data) || request.resource.data.matchCount is int);
      }
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId) && validApprovalPolicy();
      allow delete: if ownsUserNamespace(userId);
    }

    // Hermes Square Phase C — rollback requests. Phone submits, Mac claims
    // and resolves. Snapshots themselves live under cli_sessions/{id}/snapshots.
    match /users/{userId}/rollback_requests/{requestId} {
      function validRollbackRequest() {
        return request.resource.data.keys().hasOnly([
          "id", "sessionID", "scopeJSON", "requestedAt", "requestedBy",
          "status", "resolvedAt", "errorMessage", "schemaVersion", "source"
        ])
        && request.resource.data.sessionID is string
        && request.resource.data.sessionID.size() <= 256
        && request.resource.data.scopeJSON is string
        && request.resource.data.scopeJSON.size() <= 4096
        && request.resource.data.status in ["pending", "in_flight", "completed", "failed"]
        && (!("errorMessage" in request.resource.data) || (request.resource.data.errorMessage is string && request.resource.data.errorMessage.size() <= 2048));
      }
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId) && validRollbackRequest();
      allow delete: if ownsUserNamespace(userId);
    }

    // Hermes Square Phase A — per-session rollback snapshot index. Mac
    // writes (claimed device only); phone reads for the rollback picker.
    match /users/{userId}/cli_sessions/{sessionId}/snapshots/{snapshotId} {
      function validRollbackSnapshot() {
        return request.resource.data.keys().hasOnly([
          "id", "sessionID", "sequence", "takenAt", "actionLabel",
          "touchedFiles", "macSnapshotPath", "restoredAt", "schemaVersion"
        ])
        && request.resource.data.sequence is int
        && request.resource.data.sequence >= 0
        && request.resource.data.actionLabel is string
        && request.resource.data.actionLabel.size() <= 512
        && request.resource.data.touchedFiles is list
        && request.resource.data.touchedFiles.size() <= 64;
      }
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId) && validRollbackSnapshot();
      allow delete: if ownsUserNamespace(userId);
    }

    // Hermes Square Phase A/B — user-installed agent identities + persona
    // overrides. Phone-only writes. Cached locally; cloud copy survives
    // re-install.
    match /users/{userId}/agent_identities/{identityId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId)
        && request.resource.data.keys().size() <= 24;
      allow delete: if ownsUserNamespace(userId);
    }

    // Hermes Square Phase A — subscription topics with per-template consent.
    match /users/{userId}/subscription_topics/{topicId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId)
        && request.resource.data.keys().size() <= 16
        && (!("cadence" in request.resource.data) || request.resource.data.cadence in ["on_demand", "daily", "weekly", "monthly"])
        && (!("deliveryCountThisMonth" in request.resource.data) || (request.resource.data.deliveryCountThisMonth is int && request.resource.data.deliveryCountThisMonth <= 64));
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/session_logs/{logId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableSessionLogManifest(userId);
      allow delete: if ownsUserNamespace(userId);

      match /chunks/{chunkId} {
        allow read: if ownsUserNamespace(userId);
        allow create, update: if ownerWritableSessionLogChunk(userId);
        allow delete: if ownsUserNamespace(userId);
      }
    }

    match /users/{userId}/cloud_search_documents/{documentId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if false
        && request.resource.data.keys().hasOnly([
          "uid",
          "documentID",
          "deviceId",
          "sourceKind",
          "sourceID",
          "sourceVersionID",
          "provider",
          "projectName",
          "bodyHash",
          "storagePath",
          "sealedTitle",
          "sealedBodyPreview",
          "byteCount",
          "encryptedByteCount",
          "indexVersion",
          "tokenHashVersion",
          "semanticHashVersion",
          "updatedAt",
          "schemaVersion"
        ])
        && request.resource.data.uid == userId
        && request.resource.data.documentID == documentId
        && validCloudSessionStoragePath(userId, documentId, request.resource.data.bodyHash, request.resource.data.storagePath)
        && validCloudSealedText(request.resource.data.sealedTitle)
        && validCloudSealedText(request.resource.data.sealedBodyPreview)
        && request.resource.data.byteCount is int
        && request.resource.data.byteCount >= 0
        && request.resource.data.encryptedByteCount is int
        && request.resource.data.encryptedByteCount >= 1
        && request.resource.data.encryptedByteCount < 10 * 1024 * 1024
        && !("title" in request.resource.data)
        && !("snippet" in request.resource.data)
        && !("body" in request.resource.data)
        && !("text" in request.resource.data);
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/cloud_search_chunks/{chunkId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if false
        && request.resource.data.keys().hasOnly([
          "uid",
          "chunkID",
          "documentID",
          "deviceId",
          "sourceKind",
          "sourceID",
          "provider",
          "projectName",
          "ordinal",
          "startOffset",
          "endOffset",
          "contentHash",
          "bodyHash",
          "storagePath",
          "sealedSnippet",
          "tokenHashes",
          "semanticHashes",
          "indexVersion",
          "tokenHashVersion",
          "semanticHashVersion",
          "updatedAt",
          "schemaVersion"
        ])
        && request.resource.data.uid == userId
        && request.resource.data.chunkID == chunkId
        && validCloudSessionStoragePath(userId, request.resource.data.documentID, request.resource.data.bodyHash, request.resource.data.storagePath)
        && validCloudHexDigest(request.resource.data.contentHash)
        && validCloudSealedText(request.resource.data.sealedSnippet)
        && validCloudSearchHashes(request.resource.data.tokenHashes)
        && (!("semanticHashes" in request.resource.data) || validCloudSearchHashes(request.resource.data.semanticHashes))
        && (!("semanticHashVersion" in request.resource.data) || (request.resource.data.semanticHashVersion is int && request.resource.data.semanticHashVersion >= 0 && request.resource.data.semanticHashVersion <= 100))
        && !("title" in request.resource.data)
        && !("snippet" in request.resource.data)
        && !("body" in request.resource.data)
        && !("text" in request.resource.data);
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/cloud_search_postings/{postingId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if false
        && request.resource.data.keys().hasOnly([
          "uid",
          "postingKey",
          "edgeID",
          "kind",
          "hash",
          "chunkID",
          "documentID",
          "provider",
          "projectName",
          "updatedAt",
          "indexVersion",
          "schemaVersion"
        ])
        && request.resource.data.uid == userId
        && request.resource.data.edgeID == postingId
        && request.resource.data.kind in ["token", "semantic"]
        && request.resource.data.hash is string
        && request.resource.data.hash.matches("^[a-f0-9]{32}$")
        && request.resource.data.postingKey == request.resource.data.kind + "_" + request.resource.data.hash
        && request.resource.data.chunkID is string
        && request.resource.data.chunkID.size() <= 512
        && request.resource.data.edgeID == request.resource.data.postingKey + "_" + request.resource.data.chunkID
        && request.resource.data.documentID is string
        && request.resource.data.documentID.size() <= 512
        && (!("provider" in request.resource.data) || (request.resource.data.provider is string && request.resource.data.provider.size() <= 80))
        && (!("projectName" in request.resource.data) || (request.resource.data.projectName is string && request.resource.data.projectName.size() <= 512))
        && !("title" in request.resource.data)
        && !("snippet" in request.resource.data)
        && !("body" in request.resource.data)
        && !("text" in request.resource.data);
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/cloud_search_index_state/{deviceId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if false
        && request.resource.data.uid == userId
        && request.resource.data.deviceId == deviceId;
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/cloud_search_index_manifest/{manifestId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/cloud_vault_key_wrappers/{wrapperId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableHostedCloudBackup(userId)
        && request.resource.data.keys().hasOnly([
          "uid",
          "targetDeviceId",
          "sourceDeviceId",
          "publicKeyFingerprint",
          "keyVersion",
          "wrappedVaultKey",
          "algorithm",
          "status",
          "createdAt",
          "updatedAt",
          "schemaVersion"
        ])
        && request.resource.data.uid == userId
        && request.resource.data.wrappedVaultKey is string
        && request.resource.data.wrappedVaultKey.size() <= 8192
        && request.resource.data.status in ["active", "revoked"]
        && exists(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(request.resource.data.targetDeviceId))
        && get(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(request.resource.data.targetDeviceId)).data.trustState == "trusted"
        && exists(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(request.resource.data.sourceDeviceId))
        && get(/databases/$(database)/documents/users/$(userId)/escrow_devices/$(request.resource.data.sourceDeviceId)).data.trustState == "trusted";
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/devices/{deviceId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId);
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/quota_snapshots/{snapshotId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId);
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/provider_connections/{providerId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId);
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/provider_accounts/{accountId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId);
      allow delete: if ownsUserNamespace(userId);
    }

    // Provider account device links. Canonical top-level collection used by
    // `adoptProviderAccountForDevice`, `revokeProviderAccountDeviceLink`, and
    // the `backfillProviderAccountDeviceLinks` callable / schedule. Writes
    // funnel through the Admin SDK so capability values stay constrained;
    // clients are read-only.
    match /users/{userId}/provider_account_device_links/{deviceLinkId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/runtime_connection_preferences/{preferenceId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if runtimeConnectionPreferenceWrite(userId, preferenceId);
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/hermes_connections/{connectionId} {
      allow read: if ownsUserNamespace(userId);
      allow create: if relayConnectionWrite(userId, connectionId);
      allow update: if relayConnectionWrite(userId, connectionId) && resource.data.mode == "relayLink";
      allow delete: if false;
    }

    match /users/{userId}/hermes_pairings/{pairingId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/hermes_relay_requests/{requestId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if relayRequestWrite(userId, requestId);
      allow delete: if ownsUserNamespace(userId);

      match /chunks/{chunkId} {
        allow read: if ownsUserNamespace(userId);
        allow create, update: if relayChunkWrite(userId, requestId, chunkId);
        allow delete: if ownsUserNamespace(userId);
      }
    }

    match /users/{userId}/hermes_session_cache/{sessionId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/hermes_audit_events/{eventId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/pi_agent_connections/{connectionId} {
      allow read: if ownsUserNamespace(userId);
      allow create: if piRelayConnectionWrite(userId, connectionId);
      allow update: if piRelayConnectionWrite(userId, connectionId) && resource.data.mode == "relayLink";
      allow delete: if false;
    }

    match /users/{userId}/pi_agent_pairings/{pairingId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/pi_agent_relay_requests/{requestId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if piRelayRequestWrite(userId, requestId);
      allow delete: if ownsUserNamespace(userId);

      match /chunks/{chunkId} {
        allow read: if ownsUserNamespace(userId);
        allow create, update: if piRelayChunkWrite(userId, requestId, chunkId);
        allow delete: if ownsUserNamespace(userId);
      }
    }

    match /users/{userId}/pi_agent_audit_events/{eventId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/smart_hub_config/{deviceId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId)
        && request.resource.data.keys().hasOnly([
          "enabled",
          "dashboardURL",
          "refreshURL",
          "voiceRefreshURL",
          "sourceDeviceName",
          "publishedAt",
          "timePeriod",
          "pixelClock",
          "displayConfig",
          "displayOrder",
          "schemaVersion"
        ])
        && request.resource.data.enabled is bool
        && request.resource.data.schemaVersion is int
        && (!("dashboardURL" in request.resource.data) || (request.resource.data.dashboardURL is string && request.resource.data.dashboardURL.size() <= 2048))
        && (!("refreshURL" in request.resource.data) || (request.resource.data.refreshURL is string && request.resource.data.refreshURL.size() <= 2048))
        && (!("voiceRefreshURL" in request.resource.data) || (request.resource.data.voiceRefreshURL is string && request.resource.data.voiceRefreshURL.size() <= 2048))
        && (!("sourceDeviceName" in request.resource.data) || (request.resource.data.sourceDeviceName is string && request.resource.data.sourceDeviceName.size() <= 160))
        && (!("timePeriod" in request.resource.data) || request.resource.data.timePeriod in ["rolling5h", "rolling24h", "rolling7d", "rolling30d"])
        && (!("pixelClock" in request.resource.data) || validPixelClockConfig(request.resource.data.pixelClock))
        && (!("displayConfig" in request.resource.data) || validSmartHubDisplayConfig(request.resource.data.displayConfig))
        && (!("displayOrder" in request.resource.data) || validSmartDisplayOrder(request.resource.data.displayOrder));
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/smart_display_actions/{actionId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId)
        && request.resource.data.keys().hasOnly([
          "type",
          "status",
          "requestedAt",
          "completedAt",
          "errorMessage",
          "probeStatus",
          "setupMode",
          "message",
          "suggestedServerHost",
          "suggestedServerPort",
          "flasherURL",
          "refreshing",
          "pixelClock",
          "displayConfig",
          "displayOrder"
        ])
        && request.resource.data.type in [
          "pixel_clock_probe",
          "pixel_clock_prepare",
          "pixel_clock_test",
          "pixel_clock_push",
          "pixel_clock_remove",
          "pixel_clock_update_config",
          "nest_hub_update_display_config",
          "nest_hub_update_order",
          "nest_hub_refresh",
          "nest_hub_identify",
          "nest_hub_stop"
        ]
        && request.resource.data.status in ["pending", "completed", "failed"]
        && (!("errorMessage" in request.resource.data) || (request.resource.data.errorMessage is string && request.resource.data.errorMessage.size() <= 2048))
        && (!("probeStatus" in request.resource.data) || request.resource.data.probeStatus in ["unknown", "awtrixReady", "stockUlanziFirmware", "unreachable", "unsupported", "error"])
        && (!("setupMode" in request.resource.data) || request.resource.data.setupMode in ["awtrixLightReady", "stockSimulatorConfigured", "needsAwtrixLightFlash", "unreachable"])
        && (!("message" in request.resource.data) || (request.resource.data.message is string && request.resource.data.message.size() <= 2048))
        && (!("suggestedServerHost" in request.resource.data) || (request.resource.data.suggestedServerHost is string && request.resource.data.suggestedServerHost.size() <= 255))
        && (!("suggestedServerPort" in request.resource.data) || (request.resource.data.suggestedServerPort is int && request.resource.data.suggestedServerPort >= 1 && request.resource.data.suggestedServerPort <= 65535))
        && (!("flasherURL" in request.resource.data) || (request.resource.data.flasherURL is string && request.resource.data.flasherURL.size() <= 2048))
        && (!("refreshing" in request.resource.data) || request.resource.data.refreshing is bool)
        && (!("pixelClock" in request.resource.data) || validPixelClockConfig(request.resource.data.pixelClock))
        && (!("displayConfig" in request.resource.data) || validSmartHubDisplayConfig(request.resource.data.displayConfig))
        && (!("displayOrder" in request.resource.data) || validSmartDisplayOrder(request.resource.data.displayOrder));
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/cast_actions/{actionId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId)
        && request.resource.data.keys().hasOnly([
          "type",
          "status",
          "requestedAt",
          "completedAt",
          "errorMessage",
          "deviceId",
          "friendlyName",
          "model",
          "host",
          "port",
          "identifier",
          "supportsDisplay",
          "sessionId",
          "recovery",
          "message",
          "attempts"
        ])
        && request.resource.data.type in ["test", "save_selection", "cast", "stop"]
        && request.resource.data.status in ["pending", "completed", "failed"]
        && (!("errorMessage" in request.resource.data) || (request.resource.data.errorMessage is string && request.resource.data.errorMessage.size() <= 2048))
        && (!("deviceId" in request.resource.data) || (request.resource.data.deviceId is string && request.resource.data.deviceId.size() <= 512))
        && (!("friendlyName" in request.resource.data) || (request.resource.data.friendlyName is string && request.resource.data.friendlyName.size() <= 160))
        && (!("model" in request.resource.data) || (request.resource.data.model is string && request.resource.data.model.size() <= 160))
        && (!("host" in request.resource.data) || (request.resource.data.host is string && request.resource.data.host.size() <= 255))
        && (!("port" in request.resource.data) || (request.resource.data.port is int && request.resource.data.port >= 1 && request.resource.data.port <= 65535))
        && (!("identifier" in request.resource.data) || (request.resource.data.identifier is string && request.resource.data.identifier.size() <= 512))
        && (!("supportsDisplay" in request.resource.data) || request.resource.data.supportsDisplay is bool)
        && (!("sessionId" in request.resource.data) || (request.resource.data.sessionId is string && request.resource.data.sessionId.size() <= 512))
        && (!("recovery" in request.resource.data) || request.resource.data.recovery in ["home_assistant"])
        && (!("message" in request.resource.data) || (request.resource.data.message is string && request.resource.data.message.size() <= 2048))
        && (!("attempts" in request.resource.data) || (request.resource.data.attempts is int && request.resource.data.attempts >= 0 && request.resource.data.attempts <= 20));
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/cast_discovery_results/{resultId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownerWritableNonSecret(userId)
        && request.resource.data.keys().hasOnly([
          "devices",
          "publishedAt"
        ])
        && request.resource.data.devices is list
        && request.resource.data.devices.size() <= 64
        && request.resource.data.publishedAt is string
        && request.resource.data.publishedAt.size() <= 64;
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/usage_rollups/{rollupId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/projects/{projectId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/usage_counter_days/{dayId} {
      allow read, write: if false;

      match /{counterCollection}/{counterId} {
        allow read, write: if false;
      }
    }

    match /users/{userId}/usage_counter_totals/{totalId} {
      allow read, write: if false;

      match /{counterCollection}/{counterId} {
        allow read, write: if false;
      }
    }

    match /users/{userId}/rollup_jobs/{jobId} {
      allow read, write: if false;
    }

    match /users/{userId}/_rate_limits/{limitId} {
      allow read, write: if false;
    }

    match /users/{userId}/remote_mcp_clients/{clientId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/remote_mcp_grants/{grantId} {
      allow read, write: if false;
    }

    match /users/{userId}/remote_mcp_audit_events/{eventId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    match /users/{userId}/remote_mcp_rate_limits/{limitId} {
      allow read, write: if false;
    }

    // --- Apple-verified hosted-quota entitlement (server-only writer) ---
    // Cloud Functions are the sole writer; clients read their own
    // entitlement state. Trust is anchored in JWS chain verification
    // against AppleRootCA-G3 + reconciliation against the App Store
    // Server API. See `functions/src/appstore/`.
    match /users/{userId}/entitlements/{entitlementId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    // --- Apple-verified entitlement audit log (server-only writer) ---
    // Append-only log of every server-verified Apple JWS event, keyed
    // on Apple's notificationUUID where available. Owners may read for
    // support / debug; clients must never write.
    match /users/{userId}/entitlement_events/{eventId} {
      allow read: if ownsUserNamespace(userId);
      allow write: if false;
    }

    // --- appAccountToken bindings (server-only) ---
    // Server mints a UUID per signed-in user before purchase and uses
    // it to bind incoming JWS payloads to the correct UID. No client
    // surface — both read and write are denied to clients.
    match /users/{userId}/entitlement_bindings/{bindingId} {
      allow read, write: if false;
    }

    // --- Escrow: additional field-level rejection of plaintext-looking secret fields ---
    // These collections use stricter size limits and explicit plaintext-field
    // rejection where credentials could otherwise be mis-serialized.

    match /users/{userId}/escrow_devices/{deviceId} {
      function validEscrowDeviceDocument(deviceId) {
        return request.resource.data.keys().hasOnly([
          "deviceId",
          "deviceName",
          "platform",
          "appVersion",
          "trustState",
          "approvedAt",
          "createdAt",
          "updatedAt",
          "publicKeyFingerprint",
          "keyVersion"
        ])
        && request.resource.data.deviceId == deviceId
        && request.resource.data.deviceName is string
        && request.resource.data.deviceName.size() <= 256
        && request.resource.data.platform is string
        && request.resource.data.platform.size() <= 80
        && request.resource.data.trustState in ["pending", "trusted", "revoked"]
        && (!("appVersion" in request.resource.data) || (request.resource.data.appVersion is string && request.resource.data.appVersion.size() <= 80))
        && (!("publicKeyFingerprint" in request.resource.data) || (request.resource.data.publicKeyFingerprint is string && request.resource.data.publicKeyFingerprint.size() <= 256))
        && (!("keyVersion" in request.resource.data) || request.resource.data.keyVersion is int);
      }

      function validEscrowDeviceCreate(deviceId) {
        return validEscrowDeviceDocument(deviceId)
          && request.resource.data.trustState != "trusted";
      }

      function validEscrowDeviceUpdate(deviceId) {
        return validEscrowDeviceDocument(deviceId)
          && (
            request.resource.data.trustState != "trusted"
            || resource.data.trustState == "trusted"
            || (
              resource.data.trustState == "pending"
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                "trustState",
                "approvedAt",
                "updatedAt"
              ])
            )
          );
      }

      allow read: if ownsUserNamespace(userId);
      allow create: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields()
        && validEscrowDeviceCreate(deviceId);
      allow update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields()
        && validEscrowDeviceUpdate(deviceId);
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/escrow_public_keys/{keyId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields();
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/escrow_grants/{grantId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields();
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/escrow_envelopes/{envelopeId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields();
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/escrow_audit_events/{eventId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields();
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/cloud_profile/{profileId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields();
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/sync_watermarks/{watermarkId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields();
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/sync_status/{deviceId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields();
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/cloud_settings/{settingsId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields();
      allow delete: if ownsUserNamespace(userId);
    }

    match /users/{userId}/recent_usage/{summaryId} {
      allow read: if ownsUserNamespace(userId);
      allow create, update: if ownsUserNamespace(userId)
        && escrowDocumentLimits()
        && hasNoPlaintextSecretFields();
      allow delete: if ownsUserNamespace(userId);
    }

    // --- Shared artifacts (unchanged) ---

    match /workspaces/{workspaceId}/teams/{teamId}/artifacts/{artifactId} {
      allow read: if sharedArtifactOwnerRead();
      allow create, update: if sharedArtifactOwnerWrite(workspaceId, teamId);
      allow delete: if sharedArtifactOwnerRead();

      match /versions/{revisionId} {
        allow read: if sharedArtifactOwnerRead();
        allow create, update: if sharedArtifactOwnerWrite(workspaceId, teamId);
        allow delete: if sharedArtifactOwnerRead();
      }
    }
  }
}
